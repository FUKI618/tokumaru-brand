        <h2 class="display-md text-[var(--color-navy)] heading-rule center inline-block">お客様の声</h2>
        <p class="mt-7 text-[15px] text-[var(--color-text-light)] max-w-3xl mx-auto leading-loose">
          名古屋エリアの実顧客からいただいた、徳丸商会のブランド買取についてのお声です。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 stagger-children">
        {testimonials.map((t) => (
          <article class="reveal card-luxury bg-white rounded-2xl p-7 border border-[var(--color-border)] relative">
            <div class="text-7xl font-display text-[var(--color-champagne)]/30 leading-none absolute top-3 right-5">"</div>
            <div class="flex items-center gap-3 mb-5 pb-5 border-b border-[var(--color-border)] relative">
              <div class="w-12 h-12 rounded-full bg-[var(--color-navy)] text-[var(--color-champagne-glow)] flex items-center justify-center font-display text-xl">{t.initial}</div>
              <div>
                <div class="font-bold text-[var(--color-navy)] text-sm">{t.name}（{t.age}）</div>
                <div class="text-xs text-[var(--color-text-light)]">{t.area}・{t.brand}</div>
              </div>
            </div>
            <p class="text-sm text-[var(--color-text)] leading-loose relative">{t.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== XI. FAQ ============== -->
  <section id="faq" class="py-24 sm:py-32 bg-white relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-5 sm:px-8">
      <div class="text-center mb-14 reveal">
        <div class="chapter-num mb-4">ⅩⅤ. よくある質問</div>
        <h2 class="display-md text-[var(--color-navy)] heading-rule center inline-block">よくあるご質問</h2>
      </div>

      <div class="space-y-3 stagger-children">
        {faqs.map((f) => (
          <details id={f.id} class="reveal faq-item group bg-[var(--color-bg)] rounded-xl border border-[var(--color-border)] overflow-hidden hover:border-[var(--color-champagne)]/50 transition-colors">
            <summary class="flex items-center justify-between px-6 py-5 cursor-pointer hover:bg-[var(--color-cream)]/40 transition">
              <h3 class="text-sm sm:text-base font-bold text-[var(--color-navy)] pr-4 leading-snug">{f.question}</h3>
              <span class="faq-icon flex-shrink-0 w-7 h-7 rounded-full bg-[var(--color-champagne)] text-[var(--color-navy)] flex items-center justify-center text-lg font-bold" aria-hidden="true">＋</span>
            </summary>
            <div class="px-6 pb-6 text-sm text-[var(--color-text)] leading-loose">{f.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== XII. お問い合わせ + フォーム ============== -->
  <section id="contact" class="py-24 sm:py-32 bg-luxury-radial text-white relative overflow-hidden grain">
    <svg class="absolute right-0 bottom-0 w-[480px] opacity-15 pointer-events-none" viewBox="0 0 480 480" aria-hidden="true">
      <circle cx="480" cy="480" r="400" fill="none" stroke="#c5a572" stroke-width="0.5"/>
      <circle cx="480" cy="480" r="320" fill="none" stroke="#c5a572" stroke-width="0.5"/>
      <circle cx="480" cy="480" r="240" fill="none" stroke="#c5a572" stroke-width="0.5"/>
    </svg>

    <div class="max-w-[1600px] mx-auto px-5 sm:px-8 relative">
      <div class="text-center mb-14 reveal">
        <div class="chapter-num mb-4">ⅩⅥ. お問い合わせ</div>
        <h2 class="display-md heading-rule center inline-block">お見積もり・お問い合わせ</h2>
        <p class="mt-7 text-base text-[var(--color-champagne-light)] font-display tracking-wider">9:00〜21:00 ／ Open Year-round</p>
      </div>

      <div class="grid lg:grid-cols-12 gap-10">
        <!-- 左：3つの連絡手段 -->
        <div class="lg:col-span-5 reveal">
          <div class="text-[10px] tracking-[0.3em] text-[var(--color-champagne)] uppercase mb-3">QUICK CONTACT</div>
          <h3 class="font-display text-2xl mb-6">お急ぎなら直接ご連絡ください</h3>

          <div class="space-y-4">
            <a href={phoneTel} class="flex items-center gap-4 p-5 rounded-xl border border-[var(--color-champagne)]/30 bg-white/5 backdrop-blur hover:bg-white/10 hover:border-[var(--color-champagne)] transition group">
              <div class="w-12 h-12 rounded-full bg-[var(--color-champagne)] text-[var(--color-navy)] flex items-center justify-center text-2xl">📞</div>
              <div class="flex-1">
                <div class="text-[10px] tracking-wider text-white/55 uppercase">By Phone</div>
                <div class="font-display text-xl numeric tracking-wider">{company.phone}</div>
                <div class="text-[11px] text-white/55">9:00〜21:00 年中無休</div>
              </div>
              <span class="text-[var(--color-champagne)] text-xl">→</span>
            </a>

            <a href={lineUrl} target="_blank" rel="noopener" class="flex items-center gap-4 p-5 rounded-xl border border-[var(--color-line)]/35 bg-[var(--color-line)]/10 backdrop-blur hover:bg-[var(--color-line)]/15 hover:border-[var(--color-line)] transition group">
              <div class="w-12 h-12 rounded-full bg-[var(--color-line)] text-white flex items-center justify-center text-xl font-bold">L</div>
              <div class="flex-1">
                <div class="text-[10px] tracking-wider text-white/55 uppercase">LINE Quote</div>
                <div class="font-display text-xl">LINEで査定する</div>
                <div class="text-[11px] text-white/55">最短15分・写真と型番だけ</div>
              </div>
              <span class="text-[var(--color-line)] text-xl">→</span>
            </a>

            <a href={`mailto:${contactEmail}`} class="flex items-center gap-4 p-5 rounded-xl border border-white/15 bg-white/5 backdrop-blur hover:bg-white/10 hover:border-[var(--color-champagne)]/50 transition group">
              <div class="w-12 h-12 rounded-full bg-white/10 text-white flex items-center justify-center text-xl">✉</div>
              <div class="flex-1">
                <div class="text-[10px] tracking-wider text-white/55 uppercase">By Email</div>
                <div class="font-display text-base break-all">{contactEmail}</div>
                <div class="text-[11px] text-white/55">24時間受付・返信は営業時間内</div>
              </div>
              <span class="text-white/55 text-xl">→</span>
            </a>
          </div>

          <!-- 無料アピール -->
