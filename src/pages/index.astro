---
import Layout from "../layouts/Layout.astro";
import { company } from "../data/company";
import { flagshipBrands, popularBrands, buybackGuarantees } from "../data/brands";
import { faqs } from "../data/faq";
import { staff } from "../data/staff";
import { rateData, rateMetadata } from "../data/rates";
import { campaigns } from "../data/campaigns";
import { voices } from "../data/voices";
import { assetPath, sectionPath } from "../lib/site";

const title = "名古屋ブランド買取｜出張・LINE査定・宅配の徳丸商会【夜21時まで】";
const description = "名古屋市中村区の徳丸商会。エルメス・シャネル・ヴィトン・ロレックス・カルティエなど主要ブランドを高価買取。相続・形見整理に丁寧に対応。出張・LINE・宅配対応、9-21時年中無休。電話052-990-3968。古物商許可第541042309800号。";

const phoneTel = `tel:${company.phoneTel}`;
const lineUrl = company.line;
const contactEmail = "kaitori@tokumarushokai.com";

// Formspree（meenapqb 設定済み）
const FORMSPREE_FORM_ID = "meenapqb";
const formAction = FORMSPREE_FORM_ID
  ? `https://formspree.io/f/${FORMSPREE_FORM_ID}`
  : `mailto:${contactEmail}`;

// ブランドカテゴリ
const bagsBrands = popularBrands.filter((b) => b.category === "bag");
const watchesBrands = popularBrands.filter((b) => b.category === "watch");
const jewelryBrands = popularBrands.filter((b) => b.category === "jewelry");
const apparelBrands = popularBrands.filter((b) => b.category === "apparel");

// rates カテゴリ別
const bagRates = rateData.filter((r) => r.category === "bag");
const watchRates = rateData.filter((r) => r.category === "watch");
const jewelryRates = rateData.filter((r) => r.category === "jewelry");

// 万単位フォーマッタ（206万 / 13万 / 5.9万）
const formatMan = (yen: number): string => {
  const man = yen / 10000;
  if (man >= 10) return `¥${Math.round(man)}万`;
  return `¥${man.toFixed(1)}万`;
};

// midLabel "¥2,500,000 〜 ¥2,800,000" → "¥250〜280万"
const midToMan = (label: string): string => {
  const nums = label.match(/[\d,]+/g)?.map((n) => parseInt(n.replace(/,/g, ""), 10)) ?? [];
  if (nums.length !== 2) return label;
  const a = nums[0] / 10000;
  const b = nums[1] / 10000;
  if (a >= 10 && b >= 10) return `¥${Math.round(a)}〜${Math.round(b)}万`;
  return `¥${a.toFixed(1)}〜${b.toFixed(1)}万`;
};
---

<Layout title={title} description={description}>

  <!-- ============== Header ============== -->
  <header class="fixed top-0 inset-x-0 z-40 bg-[var(--color-bg)]/85 backdrop-blur-md border-b border-[var(--color-border)]">
    <div class="container-content flex items-center justify-between py-4">
      <a href={sectionPath("hero")} class="flex items-center gap-2.5" aria-label="徳丸商会 トップへ">
        <img src={assetPath("logo.svg")} alt="徳丸商会" class="h-8 w-auto" width="36" height="36" />
        <div class="leading-tight">
          <div class="text-[11px] tracking-[0.25em] text-[var(--color-text)] uppercase font-medium">Tokumaru Shokai</div>
          <div class="text-[9px] tracking-[0.3em] text-[var(--color-text-sub)] uppercase mt-0.5">Nagoya</div>
        </div>
      </a>
      <nav class="hidden lg:flex items-center gap-7 text-[13px]" aria-label="セクションナビ">
        <a href={sectionPath("story")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">買取の姿勢</a>
        <a href={sectionPath("rates")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">参考買取相場</a>
        <a href={sectionPath("methods")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">買取方法</a>
        <a href={sectionPath("campaigns")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">キャンペーン</a>
        <a href={sectionPath("faq")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">FAQ</a>
        <a href={sectionPath("contact")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">お問い合わせ</a>
      </nav>
      <div class="hidden md:flex items-center gap-2">
        <a href={phoneTel} class="btn btn-outline btn-sm">
          いますぐ電話
        </a>
        <a href={lineUrl} target="_blank" rel="noopener" class="btn btn-line btn-sm">LINEで査定</a>
      </div>
    </div>
  </header>

  <!-- ============== 1. Hero ============== -->
  <section id="hero" class="relative overflow-hidden bg-[var(--color-bg-2)] lg:min-h-[90vh]">

    <!-- 背景：暖色オフホワイト + 薄いペーパーテクスチャ -->
    <div class="absolute inset-0" aria-hidden="true" style="background: linear-gradient(180deg, var(--color-bg-2) 0%, var(--color-bg) 100%);"></div>
    <div class="absolute inset-0 grain-soft" aria-hidden="true"></div>

    <!-- PC: 右側にサイドアクセントとして画像（mask 10% で世界観をしっかり見せる） -->
    <picture class="absolute right-0 top-0 bottom-0 w-1/2 hidden lg:block opacity-95" aria-hidden="true" style="mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 100%); -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 100%);">
      <source srcset={assetPath("images/hero/luxury-bg.webp")} type="image/webp" />
      <img src={assetPath("images/hero/luxury-bg.jpg")} alt="窓際の白いリネンに置かれた淡い色のシルクスカーフ" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1920" height="1080" />
    </picture>

    <!-- モバイル: 上部に大きな画像ヘッダー（Aesop 風 editorial）。h-[58svh] で視認性確保 / portrait 3:4 で縦構図 -->
    <div class="relative lg:hidden h-[58svh] overflow-hidden">
      <picture class="absolute inset-0" aria-hidden="true">
        <source srcset={assetPath("images/hero/luxury-bg-portrait.webp")} type="image/webp" />
        <img src={assetPath("images/hero/luxury-bg-portrait.jpg")} alt="窓際の白いリネンに置かれた小さな陶器の花瓶と一輪の枯れ枝" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1200" height="1600" />
      </picture>
      <!-- 下端へのグラデフェード（コンテンツへ繋ぐ） -->
      <div class="absolute inset-x-0 bottom-0 h-2/5 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, var(--color-bg-2) 100%);"></div>
      <!-- モバイル：画像下部に Numero 装飾を浮かせる -->
      <div class="absolute left-6 bottom-6 z-10">
        <div class="flex items-center gap-3">
          <span class="block w-10 h-px bg-[var(--color-accent-soft)]"></span>
          <div class="eyebrow text-[var(--color-text)]">Nagoya, since 1992</div>
        </div>
      </div>
    </div>

    <!-- 装飾SVG: 右上の細い円弧（Khaite風 / PCのみ） -->
    <svg class="deco-svg w-[240px] h-[240px] hidden md:block" style="top: 14%; right: 8%; opacity: 0.35;" viewBox="0 0 280 280" fill="none" aria-hidden="true">
      <circle cx="140" cy="140" r="138" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 4" />
      <circle cx="140" cy="140" r="100" stroke="currentColor" stroke-width="0.5" />
      <line x1="140" y1="40" x2="140" y2="240" stroke="currentColor" stroke-width="0.3" />
      <line x1="40" y1="140" x2="240" y2="140" stroke="currentColor" stroke-width="0.3" />
    </svg>

    <!-- 装飾SVG: 左下のシンプルなバッグアウトライン（PCのみ） -->
    <svg class="deco-svg deco-svg-warm w-[110px] h-[130px] hidden md:block" style="bottom: 22%; left: 5%; opacity: 0.3;" viewBox="0 0 120 140" fill="none" stroke="currentColor" stroke-width="0.8" aria-hidden="true">
      <path d="M20,60 L100,60 L92,130 L28,130 Z" />
      <path d="M40,60 Q40,30 60,30 Q80,30 80,60" />
      <line x1="40" y1="80" x2="40" y2="100" />
      <line x1="80" y1="80" x2="80" y2="100" />
    </svg>

    <!-- 大きな装飾文字（PCのみ） -->
    <div class="bg-letter hidden md:block" style="bottom: 4%; left: -2%; opacity: 0.06;" aria-hidden="true">T</div>

    <!-- コンテンツ: モバイル=画像下にスタック、PC=絶対配置で底に揃える -->
    <div class="relative lg:absolute lg:inset-0 lg:flex lg:items-end z-10">
      <div class="container-content w-full pt-8 pb-12 lg:pt-32 lg:pb-20">
        <div class="grid lg:grid-cols-12 gap-8 items-end">
          <div class="lg:col-span-8 reveal">
            <!-- eyebrow（PCのみ・モバイルは画像オーバーレイ側で表示） -->
            <div class="hidden lg:flex items-center gap-3 mb-6">
              <span class="block w-12 h-px bg-[var(--color-accent-soft)]"></span>
              <div class="eyebrow">Nagoya, since 1992</div>
            </div>

            <h1 class="display-1 mb-6 max-w-3xl" aria-label="名古屋でブランド品の買取なら徳丸商会｜エルメス・シャネル・ヴィトン・ロレックス・カルティエを高価買取">
              <span class="block">価値が分かる店で、</span>
              <span class="block italic font-serif" style="color: var(--color-accent-soft);">手放す<span class="text-[var(--color-text)] not-italic">。</span></span>
            </h1>

            <!-- 装飾線 + コピー -->
            <div class="line-vertical pl-6 max-w-xl mb-8">
              <p class="text-base md:text-lg text-[var(--color-text-sub)] leading-loose">
                名古屋でブランド品の買取なら徳丸商会へ。<br />
                ご自宅までお伺いする出張買取・LINE査定・宅配買取に対応。<br />
                <span class="text-[var(--color-text)]">親から受け継いだ品も、長く眠っていた品も、<wbr />一点ずつ丁寧に拝見します。</span>
              </p>
            </div>

            <!-- 取扱ブランド ストリップ -->
            <div class="hidden md:flex items-center gap-4 mt-8 flex-wrap" aria-label="取扱主要ブランド">
              {flagshipBrands.map((b, i) => (
                <>
                  {i > 0 && <span class="text-[var(--color-text)] opacity-30">·</span>}
                  <span class="font-serif italic text-[var(--color-text)] text-base tracking-wider">{b.name}</span>
                </>
              ))}
            </div>
          </div>

          <div class="lg:col-span-4 reveal reveal-delay-1">
            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] p-6 deco-corners">
              <div class="numero mb-5">N° 01</div>
              <div class="flex flex-col gap-3">
                <a href={lineUrl} target="_blank" rel="noopener" class="btn btn-line btn-lg w-full">
                  LINEで無料査定
                </a>
                <a href={phoneTel} class="btn btn-outline w-full">
                  いますぐ電話する
                </a>
                <a href={sectionPath("contact")} class="text-center text-[13px] text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition pt-2 underline-offset-4 hover:underline">
                  フォームから相談する
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </section>

  <!-- セクション間装飾divider -->
  <div class="bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="section-divider">
        <span class="section-divider-motif">i</span>
      </div>
    </div>
  </div>

  <!-- ============== 2. Story（コア訴求） ============== -->
  <section id="story" class="dossier-section dossier-section-dark relative overflow-hidden">
    <!-- 装飾的な大きな背景文字 -->
    <div class="bg-letter" style="top: 5%; right: -3%;" aria-hidden="true">II</div>

    <div class="container-content relative">
      <div class="dossier-spread">
        <div class="dossier-intro reveal">
          <div class="flex items-center gap-3 mb-4">
            <span class="numero">N° 02</span>
            <span class="block w-8 h-px bg-[var(--color-border)]"></span>
            <span class="eyebrow">私たちの姿勢</span>
          </div>
          <h2 class="dossier-title mb-8">
            他店で値が付かなかった<br />品も、<span class="italic" style="color: var(--color-accent-soft);">丁寧に</span>拝見します。
          </h2>
          <p class="dossier-copy text-base text-[var(--color-text-sub)] leading-loose">
            「もう古いから」「使用感があるから」「保証書がないから」——<br />
            そんな理由で諦めたお品を、もう一度お持ちいただきたいのです。
          </p>

          <!-- 装飾的シルエット（査定員の手＝小さなSVG） -->
          <svg class="mt-12 w-32 h-auto opacity-30" viewBox="0 0 200 80" fill="none" stroke="currentColor" stroke-width="0.8" style="color: var(--color-accent-soft);" aria-hidden="true">
            <line x1="10" y1="40" x2="60" y2="40" />
            <circle cx="80" cy="40" r="14" />
            <circle cx="80" cy="40" r="8" stroke-dasharray="2 2" />
            <line x1="100" y1="40" x2="190" y2="40" />
            <text x="120" y="35" font-family="serif" font-style="italic" font-size="9" fill="currentColor" stroke="none" opacity="0.7">— 一点ずつ、丁寧に</text>
          </svg>
        </div>

        <div class="dossier-stack lg:pl-8 lg:border-l lg:border-[var(--color-border)]">
          <div class="dossier-inner-grid">
            <figure class="editorial-figure dossier-photo-card reveal reveal-delay-1">
              <picture class="editorial-media aspect-[4/5] md:aspect-[5/6]">
                <source media="(min-width: 1024px)" srcset={assetPath("images/sections/story-notebook.webp")} type="image/webp" />
                <source media="(min-width: 1024px)" srcset={assetPath("images/sections/story-notebook.jpg")} type="image/jpeg" />
                <source srcset={assetPath("images/sections/story-notebook-portrait.webp")} type="image/webp" />
                <img src={assetPath("images/sections/story-notebook-portrait.jpg")} alt="木のテーブルに置かれた革のノートブックと真鍮の万年筆、窓からの斜光" loading="lazy" width="1200" height="1600" />
              </picture>
              <figcaption class="editorial-caption">
                査定の記録は、一点ごとの状態と背景を残すところから始まります。
              </figcaption>
            </figure>

            <div class="dossier-quote-card reveal reveal-delay-2">
              <div class="quote-large text-base text-[var(--color-text)] leading-loose font-serif italic">
                <p class="not-italic font-sans text-[var(--color-text-sub)] mb-4 text-sm tracking-wider">{staff[1].surname}（{staff[1].role}）</p>
                <p>{staff[1].message}</p>
                <p class="mt-6 not-italic text-sm font-medium text-[var(--color-text)]">— {staff[1].policy}</p>
              </div>
            </div>
          </div>

          <hr class="divider reveal" />

          <div class="dossier-condition-grid reveal reveal-delay-3">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-3 text-sm">
              {[
                "保証書なし",
                "箱・付属品なし",
                "使用感あり",
                "小さな破れ",
                "金具のくすみ",
                "メッキ剥がれ",
                "不動の時計",
                "経年劣化",
              ].map((c) => (
                <div class="flex items-baseline gap-2 py-1 border-b border-[var(--color-border)]">
                  <span class="text-[var(--color-accent-soft)] text-xs">○</span>
                  <span class="text-[var(--color-text-sub)]">{c}</span>
                </div>
              ))}
            </div>
            <p class="text-xs text-[var(--color-text-sub)] mt-4">いずれの状態でも、まずは一度ご相談ください。</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- セクション間装飾 -->
  <div class="bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="section-divider">
        <span class="section-divider-motif">ii</span>
      </div>
    </div>
  </div>

  <!-- ============== 3. Rates（参考買取相場） ============== -->
  <section id="rates" class="section-pad bg-[var(--color-bg-2)] relative overflow-hidden">
    <div class="bg-letter" style="bottom: -8%; left: -2%;" aria-hidden="true">III</div>

    <div class="container-content relative">
      <div class="grid lg:grid-cols-12 gap-8 mb-12 reveal">
        <div class="lg:col-span-5">
          <div class="flex items-center gap-3 mb-4">
            <span class="numero">N° 03</span>
            <span class="block w-8 h-px bg-[var(--color-border)]"></span>
            <span class="eyebrow">主要ブランドの参考買取相場</span>
          </div>
          <h2 class="display-2">相場で見る、<br />買取の<span class="italic" style="color: var(--color-accent-soft);">目安。</span></h2>
        </div>
        <div class="lg:col-span-7 lg:pt-6">
          <p class="text-[15px] text-[var(--color-text-sub)] leading-loose">
            主要ブランドの公開買取実績から3社以上の実数値をクロスチェックして算出した、エルメス・シャネル・ロレックス等を含む12モデルの参考相場です。
            <span class="text-xs block mt-2">集計期間：{rateMetadata.collectionPeriod} ／ 更新：{rateMetadata.updatedAt}</span>
          </p>
        </div>
      </div>

      <!-- 主要ブランド最低買取保証額（Story から移動） -->
      <div class="mb-14 reveal">
        <div class="border border-[var(--color-border)] bg-[var(--color-bg)] p-6 md:p-8">
          <div class="flex items-baseline justify-between mb-5 pb-3 border-b border-[var(--color-border)]">
            <div class="eyebrow">主要ブランドの最低買取保証額</div>
            <div class="text-[10px] text-[var(--color-text-sub)] tracking-widest hidden sm:block">Minimum Guaranteed Buyback</div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-y-5 gap-x-4">
            {buybackGuarantees.map((g) => (
              <div class="text-center sm:text-left">
                <div class="font-serif text-[var(--color-text)]">{g.brand}</div>
                <div class="text-[10px] text-[var(--color-text-sub)] mb-2">{g.jpName}</div>
                <div class="font-sans tabular-nums text-lg text-[var(--color-text)]" style="color: var(--color-accent-soft);">¥{g.minPrice.toLocaleString()}〜</div>
              </div>
            ))}
          </div>
          <p class="text-[11px] text-[var(--color-text-sub)] mt-5 leading-relaxed">
            ※ 正規品確認後、状態問わず最低買取保証額をお約束します。詳細条件はお問い合わせください。
          </p>
        </div>
      </div>

      {[
        { id: "bag", label: "バッグ", items: bagRates },
        { id: "watch", label: "時計", items: watchRates },
        { id: "jewelry", label: "ジュエリー", items: jewelryRates },
      ].map((cat, idx) => (
        <div class="mb-10 lg:mb-12 reveal" x-data={`{ open: ${idx === 0 ? "true" : "false"} }`}>
          <button
            type="button"
            @click="open = !open"
            class="w-full flex items-end justify-between mb-6 pb-3 border-b border-[var(--color-border)] lg:cursor-default lg:pointer-events-none"
            :aria-expanded="open"
            aria-controls={`rates-${cat.id}`}
          >
            <h3 class="font-serif text-xl text-[var(--color-text)]">{cat.label}</h3>
            <div class="flex items-center gap-3">
              <div class="text-xs text-[var(--color-text-sub)] numeric tracking-wider">{cat.items.length} models</div>
              <svg class="lg:hidden w-3.5 h-3.5 text-[var(--color-text-sub)] transition-transform duration-200" :class="open && 'rotate-180'" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M2 4l4 4 4-4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </button>
          <div id={`rates-${cat.id}`} class="lg:!block" :class="!open && 'hidden'">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0">
              {cat.items.map((r) => (
                <article class="py-6 border-t border-[var(--color-border)]">
                  <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-3">
                    <div class="md:flex-1">
                      <div class="flex items-baseline gap-3 mb-1">
                        <span class="font-serif text-base text-[var(--color-text)] tracking-wide">{r.brand}</span>
                        <span class="text-[10px] text-[var(--color-text-sub)] tracking-widest">×{r.sources}社調査</span>
                      </div>
                      <div class="text-[15px] text-[var(--color-text)] font-medium">{r.model}</div>
                      {r.variant && <div class="text-[11px] text-[var(--color-text-sub)] mt-0.5">{r.variant}</div>}
                    </div>
                    <div class="md:text-right whitespace-nowrap">
                      <div class="font-sans tabular-nums font-normal text-[26px] md:text-[30px] leading-none text-[var(--color-text)] tracking-tight">
                        {formatMan(r.min)}<span class="text-[var(--color-text-sub)] text-[20px] mx-2 font-light">〜</span>{formatMan(r.max)}
                      </div>
                      <div class="font-sans tabular-nums text-[11px] text-[var(--color-text-sub)] mt-2 tracking-tight">
                        中心帯 <span style="color: var(--color-accent-soft);">{midToMan(r.midLabel)}</span>
                      </div>
                    </div>
                  </div>
                  {r.note && (
                    <p class="text-[10px] text-[var(--color-text-sub)] mt-3 leading-relaxed">※ {r.note}</p>
                  )}
                </article>
              ))}
            </div>
          </div>
        </div>
      ))}

      <p class="text-xs text-[var(--color-text-sub)] mt-10 max-w-3xl leading-relaxed">
        ※ 表示金額の幅は「使用感あり・付属品なしの最低帯」から「未使用品・人気色のプレミアム上限」までを示します。<br />
        ※ 「中心帯」は集計データの中位レンジで、最も多く取引されている価格帯です。<br />
        ※ {rateMetadata.disclaimer}
      </p>
