---
import Layout from "../layouts/Layout.astro";
import { company } from "../data/company";
import { flagshipBrands, popularBrands, buybackGuarantees } from "../data/brands";
import { faqs } from "../data/faq";
import { staff } from "../data/staff";
import { rateData, rateMetadata } from "../data/rates";
import { campaigns } from "../data/campaigns";
import { voices } from "../data/voices";
import { assetPath, sectionPath } from "../lib/site";
import { yearDotMonth, monthJP } from "../lib/calendar";

const title = "名古屋ブランド買取｜出張・LINE査定・宅配の徳丸商会【夜21時まで】";
const description = "名古屋市中村区の徳丸商会。エルメス・シャネル・ヴィトン・ロレックス・カルティエなど主要ブランドを高価買取。相続・形見整理に丁寧に対応。出張・LINE・宅配対応、9-21時年中無休。電話052-990-3968。古物商許可第541042309800号。";

const phoneTel = `tel:${company.phoneTel}`;
const lineUrl = company.line;
const contactEmail = "kaitori@tokumarushokai.com";

// Formspree（meenapqb 設定済み）
const FORMSPREE_FORM_ID = "meenapqb";
const formAction = FORMSPREE_FORM_ID
  ? `https://formspree.io/f/${FORMSPREE_FORM_ID}`
  : `mailto:${contactEmail}`;

// ブランドカテゴリ
const bagsBrands = popularBrands.filter((b) => b.category === "bag");
const watchesBrands = popularBrands.filter((b) => b.category === "watch");
const jewelryBrands = popularBrands.filter((b) => b.category === "jewelry");
const apparelBrands = popularBrands.filter((b) => b.category === "apparel");

// rates カテゴリ別
const bagRates = rateData.filter((r) => r.category === "bag");
const watchRates = rateData.filter((r) => r.category === "watch");
const jewelryRates = rateData.filter((r) => r.category === "jewelry");

// 万単位フォーマッタ（206万 / 13万 / 5.9万）
const formatMan = (yen: number): string => {
  const man = yen / 10000;
  if (man >= 10) return `¥${Math.round(man)}万`;
  return `¥${man.toFixed(1)}万`;
};

// midLabel "¥2,500,000 〜 ¥2,800,000" → "¥250〜280万"
const midToMan = (label: string): string => {
  const nums = label.match(/[\d,]+/g)?.map((n) => parseInt(n.replace(/,/g, ""), 10)) ?? [];
  if (nums.length !== 2) return label;
  const a = nums[0] / 10000;
  const b = nums[1] / 10000;
  if (a >= 10 && b >= 10) return `¥${Math.round(a)}〜${Math.round(b)}万`;
  return `¥${a.toFixed(1)}〜${b.toFixed(1)}万`;
};
---

<Layout title={title} description={description}>

  <!-- ============== Header ============== -->
  <header class="fixed top-0 inset-x-0 z-40 bg-[var(--color-bg)]/85 backdrop-blur-md border-b border-[var(--color-border)]">
    <div class="container-content flex items-center justify-between py-4">
      <a href={sectionPath("hero")} class="flex items-center gap-2.5" aria-label="徳丸商会 トップへ">
        <img src={assetPath("logo.svg")} alt="徳丸商会" class="h-8 w-auto" width="36" height="36" />
        <div class="leading-tight">
          <div class="text-[11px] tracking-[0.25em] text-[var(--color-text)] uppercase font-medium">Tokumaru Shokai</div>
          <div class="text-[9px] tracking-[0.3em] text-[var(--color-text-sub)] uppercase mt-0.5">Nagoya</div>
        </div>
      </a>
      <nav class="hidden lg:flex items-center gap-7 text-[13px]" aria-label="セクションナビ">
        <a href={sectionPath("story")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">買取の姿勢</a>
        <a href={sectionPath("rates")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">参考買取相場</a>
        <a href={sectionPath("methods")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">買取方法</a>
        <a href={sectionPath("campaigns")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">キャンペーン</a>
        <a href={sectionPath("faq")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">FAQ</a>
        <a href={sectionPath("contact")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">お問い合わせ</a>
      </nav>
      <!-- PC: テキスト付きCTA -->
      <div class="hidden md:flex items-center gap-2">
        <a href={phoneTel} class="btn btn-outline btn-sm">
          いますぐ電話
        </a>
        <a href={lineUrl} target="_blank" rel="noopener" class="btn btn-line btn-sm">LINEで査定</a>
      </div>
      <!-- モバイル: アイコン圧縮CTA（常時表示・即タップ可） -->
      <div class="flex md:hidden items-center gap-1.5">
        <a href={phoneTel} aria-label="電話で問い合わせ" class="inline-flex items-center justify-center w-9 h-9 border border-[var(--color-text)] text-[var(--color-text)] hover:bg-[var(--color-text)] hover:text-[var(--color-bg)] transition">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
        </a>
        <a href={lineUrl} target="_blank" rel="noopener" aria-label="LINEで査定" class="inline-flex items-center justify-center px-3 h-9 bg-[var(--color-line)] text-white text-[11px] font-semibold tracking-wider">
          LINE
        </a>
      </div>
    </div>
  </header>

  <!-- ============== 1. Hero — listing-ad conversion layout ============== -->
  <section id="hero" class="hero-v2">

    <!-- Generated hero image: premium listing-ad conversion visual -->
    <div class="hero-v2-mobile-image">
      <picture class="absolute inset-0" aria-hidden="true">
        <source srcset={assetPath("images/generated/ad-hero-mobile.webp")} type="image/webp" />
        <img src={assetPath("images/generated/ad-hero-mobile.jpg")} alt="ブランド品査定の現場。革のハンドバッグ、腕時計、白手袋、スマートフォン、真鍮のルーペ。" class="w-full h-full object-cover object-bottom" loading="eager" fetchpriority="high" width="1200" height="1500" />
      </picture>
      <div class="absolute inset-x-0 bottom-0 h-2/5 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, var(--color-bg-3) 100%);"></div>
      <div class="absolute left-6 bottom-6 z-10">
        <div class="flex items-center gap-3">
          <span class="block w-10 h-px bg-[var(--color-accent-warm)]"></span>
          <div class="eyebrow text-[var(--color-text)]">LINE査定 — 最短15分</div>
        </div>
      </div>
    </div>

    <!-- PC: conversion panel + generated image / Mobile: stacked content -->
    <div class="hero-v2-grid">
      <div class="hero-v2-panel">
        <div class="hero-v2-panel-inner reveal">
          <div class="hero-v2-eyebrow">
            <span class="hero-v2-eyebrow-label">名古屋ブランド買取 / 広告限定導線</span>
          </div>

          <h1 class="hero-v2-title" aria-label="名古屋でブランド品を売るなら、まずLINEで相場確認。徳丸商会の出張買取・LINE査定・宅配買取">
            <span class="hero-v2-title-en">売る前に、</span>
            <span class="hero-v2-title-jp"><em>相場を確認</em>。</span>
          </h1>

          <p class="hero-v2-lead">
            バッグ・時計・ジュエリーの写真を送るだけ。<br />
            名古屋の査定員が、出張前に目安額をお返しします。
          </p>

          <div class="hero-v2-proof-grid" aria-label="徳丸商会の査定メリット">
            <div class="hero-v2-proof">
              <span>LINE査定</span>
              <strong>最短15分</strong>
            </div>
            <div class="hero-v2-proof">
              <span>出張・査定</span>
              <strong>無料</strong>
            </div>
            <div class="hero-v2-proof">
              <span>受付</span>
              <strong>21時まで</strong>
            </div>
          </div>

          <dl class="hero-v2-meta">
            <div class="hero-v2-meta-row">
              <dt>取扱</dt>
              <dd>エルメス・シャネル・ヴィトン・ロレックス・カルティエ</dd>
            </div>
            <div class="hero-v2-meta-row">
              <dt>方法</dt>
              <dd>出張買取 ／ LINE査定 ／ 宅配買取</dd>
            </div>
            <div class="hero-v2-meta-row">
              <dt>所在</dt>
              <dd>名古屋市中村区横井 ／ 9:00–21:00 年中無休</dd>
            </div>
            <div class="hero-v2-meta-row">
              <dt>許可</dt>
              <dd>愛知県公安委員会 第541042309800号</dd>
            </div>
          </dl>

          <div class="hero-v2-cta">
            <a href={lineUrl} target="_blank" rel="noopener" class="hero-v2-cta-primary">
              <span class="hero-v2-cta-primary-label">LINEで相場を確認する</span>
              <span class="hero-v2-cta-primary-meta">写真だけ / 最短15分 / 公式LINE特典 +3% UP</span>
            </a>
            <div class="hero-v2-cta-row">
              <a href={phoneTel} class="hero-v2-cta-secondary">
                <span class="hero-v2-cta-secondary-label">電話で相談</span>
                <span class="hero-v2-cta-secondary-num">{company.phone}</span>
              </a>
              <a href={sectionPath("contact")} class="hero-v2-cta-tertiary">
                フォーム →
              </a>
            </div>
          </div>

          <a href={sectionPath("campaigns")} class="hero-v2-campaign">
            <span class="hero-v2-campaign-tag">期間限定 {yearDotMonth}</span>
            <span>主要ブランド <em>買取UP +5〜10%</em> / 初回相談無料</span>
          </a>
        </div>
      </div>

      <div class="hero-v2-image">
        <picture>
          <source srcset={assetPath("images/generated/ad-hero-desktop.webp")} type="image/webp" />
          <img src={assetPath("images/generated/ad-hero-desktop.jpg")} alt="ブランド品査定の現場。革のハンドバッグ、腕時計、白手袋、スマートフォン、真鍮のルーペ。" loading="eager" fetchpriority="high" width="1920" height="1080" />
        </picture>
        <div class="hero-v2-image-caption">
          <span class="hero-v2-image-caption-label">査定前に分かること</span>
          <span class="hero-v2-image-caption-text">現在の相場帯 / 付属品の影響 / 売り時</span>
          <span class="hero-v2-image-caption-est">例：HERMES バーキン25 ¥206〜390万</span>
        </div>
      </div>
    </div>

  </section>

  <!-- ============== Hero 直下: 主要ブランド買取相場 3枚（広告LP/即理解） ============== -->
  <div class="hero-rate-strip" aria-label="主要ブランドの買取相場ハイライト">
    <div class="container-content">
      <div class="hero-rate-header">
        <span class="hero-rate-eyebrow">主要モデルの買取相場</span>
        <span class="hero-rate-meta">3社以上クロスチェック ／ {yearDotMonth} 更新</span>
      </div>
      <div class="hero-rate-grid">
        <a href={sectionPath("rates")} class="hero-rate-card hero-rate-card-bag">
          <div class="hero-rate-brand">HERMES</div>
          <div class="hero-rate-model">バーキン<span class="hero-rate-num-small">25</span></div>
          <div class="hero-rate-price">¥206<span class="hero-rate-tilde">〜</span>390<span class="hero-rate-unit">万</span></div>
          <div class="hero-rate-note">トゴ／ブラック × 5社調査</div>
        </a>
        <a href={sectionPath("rates")} class="hero-rate-card hero-rate-card-watch">
          <div class="hero-rate-brand">ROLEX</div>
          <div class="hero-rate-model">サブマリーナ</div>
          <div class="hero-rate-price">¥148<span class="hero-rate-tilde">〜</span>219<span class="hero-rate-unit">万</span></div>
          <div class="hero-rate-note">124060 × 5社調査</div>
        </a>
        <a href={sectionPath("rates")} class="hero-rate-card hero-rate-card-jewelry">
          <div class="hero-rate-brand">CHANEL</div>
          <div class="hero-rate-model">マトラッセ<span class="hero-rate-num-small">ラージ</span></div>
          <div class="hero-rate-price">¥43<span class="hero-rate-tilde">〜</span>91<span class="hero-rate-unit">万</span></div>
          <div class="hero-rate-note">デカマトラッセ30 × 4社調査</div>
        </a>
      </div>
      <a href={sectionPath("rates")} class="hero-rate-more">
        全12モデルの買取相場を見る →
      </a>
    </div>
  </div>

  <!-- ============== Hero 信頼ストリップ（広告LP用 / 4信頼指標） ============== -->
  <div class="hero-trust-strip" aria-label="徳丸商会の信頼指標">
    <div class="container-content">
      <div class="hero-trust-grid">
        <div class="hero-trust-item">
          <div class="hero-trust-num hero-trust-num-jp" style="color: var(--color-text);">最短当日</div>
          <div class="hero-trust-label">名古屋市内 訪問</div>
        </div>
        <div class="hero-trust-item">
          <div class="hero-trust-num">9–21<span class="hero-trust-num-suffix">時</span></div>
          <div class="hero-trust-label">年中無休</div>
        </div>
        <div class="hero-trust-item">
          <div class="hero-trust-num hero-trust-num-jp">無料</div>
          <div class="hero-trust-label">出張・査定・キャンセル</div>
        </div>
        <div class="hero-trust-item">
          <div class="hero-trust-num hero-trust-num-license">541042309800</div>
          <div class="hero-trust-label">愛知県公安委員会許可</div>
        </div>
      </div>
    </div>
  </div>

  <!-- セクション間装飾divider -->
  <div class="bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="section-divider">
        <span class="section-divider-motif">i</span>
      </div>
    </div>
  </div>

  <!-- ============== 2. Story（コア訴求） ============== -->
  <section id="story" class="dossier-section dossier-section-dark relative overflow-hidden">
    <!-- 装飾的な大きな背景文字 -->
    <div class="bg-letter" style="top: 5%; right: -3%;" aria-hidden="true">II</div>

    <div class="container-content relative">
      <div class="dossier-spread">
        <div class="dossier-intro reveal">
          <div class="flex items-center gap-3 mb-4">
            <span class="block w-8 h-px bg-[var(--color-border)]"></span>
            <span class="eyebrow">ブランド買取の姿勢</span>
          </div>
          <h2 class="dossier-title mb-8" aria-label="ブランド買取の姿勢｜他店で値が付かなかった品も丁寧に拝見します">
            他店で値が付かなかった<br />品も、<span class="italic" style="color: var(--color-accent-soft);">丁寧に</span>拝見します。
          </h2>
          <p class="dossier-copy text-base text-[var(--color-text-sub)] leading-loose">
            「もう古いから」「使用感があるから」「保証書がないから」——<br />
            そんな理由で諦めたお品を、もう一度お持ちいただきたいのです。
          </p>

          <!-- 装飾的シルエット（査定員の手＝小さなSVG） -->
          <svg class="mt-12 w-32 h-auto opacity-30" viewBox="0 0 200 80" fill="none" stroke="currentColor" stroke-width="0.8" style="color: var(--color-accent-soft);" aria-hidden="true">
            <line x1="10" y1="40" x2="60" y2="40" />
            <circle cx="80" cy="40" r="14" />
            <circle cx="80" cy="40" r="8" stroke-dasharray="2 2" />
            <line x1="100" y1="40" x2="190" y2="40" />
            <text x="120" y="35" font-family="serif" font-style="italic" font-size="9" fill="currentColor" stroke="none" opacity="0.7">— 一点ずつ、丁寧に</text>
          </svg>
        </div>

        <div class="dossier-stack lg:pl-8 lg:border-l lg:border-[var(--color-border)]">
          <!-- 主役画像（全幅・大判）を最上段に -->
          <figure class="editorial-figure dossier-photo-card reveal reveal-delay-1">
            <picture class="editorial-media aspect-[3/4] lg:aspect-[4/3]">
              <source media="(min-width: 1024px)" srcset={assetPath("images/generated/pro-tools.webp")} type="image/webp" />
              <source media="(min-width: 1024px)" srcset={assetPath("images/generated/pro-tools.jpg")} type="image/jpeg" />
              <source srcset={assetPath("images/generated/pro-tools.webp")} type="image/webp" />
              <img src={assetPath("images/generated/pro-tools.jpg")} alt="査定道具の静物写真。白手袋、真鍮の拡大鏡、天秤、空のトレー。" loading="lazy" width="1920" height="1080" />
            </picture>
            <figcaption class="editorial-caption">
              査定の記録は、一点ごとの状態と背景を残すところから始まります。
            </figcaption>
          </figure>

          <!-- 査定員の声（画像の下に配置） -->
          <div class="dossier-quote-card reveal reveal-delay-2">
            <div class="quote-large text-base text-[var(--color-text)] leading-loose font-serif italic">
              <p class="not-italic font-sans text-[var(--color-text-sub)] mb-4 text-sm tracking-wider">{staff[1].surname}（{staff[1].role}）</p>
              <p>{staff[1].message}</p>
              <p class="mt-6 not-italic text-sm font-medium text-[var(--color-text)]">— {staff[1].policy}</p>
            </div>
          </div>

          <hr class="divider reveal" />

          <div class="dossier-condition-grid reveal reveal-delay-3">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-3 text-sm">
              {[
                "保証書なし",
                "箱・付属品なし",
                "使用感あり",
                "小さな破れ",
                "金具のくすみ",
                "メッキ剥がれ",
                "不動の時計",
                "経年劣化",
              ].map((c) => (
                <div class="flex items-baseline gap-2 py-1 border-b border-[var(--color-border)]">
                  <span class="text-[var(--color-accent-soft)] text-xs">○</span>
                  <span class="text-[var(--color-text-sub)]">{c}</span>
                </div>
              ))}
            </div>
            <p class="text-xs text-[var(--color-text-sub)] mt-4">いずれの状態でも、まずは一度ご相談ください。</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- セクション間装飾 -->
  <div class="bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="section-divider">
        <span class="section-divider-motif">ii</span>
      </div>
    </div>
  </div>

  <!-- ============== 3. Rates（参考買取相場） ============== -->
  <section id="rates" class="section-pad bg-[var(--color-bg-2)] relative overflow-hidden">
    <div class="bg-letter" style="bottom: -8%; left: -2%;" aria-hidden="true">III</div>

    <div class="container-content relative">
      <div class="grid lg:grid-cols-12 gap-8 mb-12 reveal">
        <div class="lg:col-span-5">
          <div class="flex items-center gap-3 mb-4">
            <span class="block w-8 h-px bg-[var(--color-border)]"></span>
            <span class="eyebrow">主要ブランドの参考買取相場</span>
          </div>
          <h2 class="display-2">相場で見る、<br />買取の<span class="italic" style="color: var(--color-accent-soft);">目安。</span></h2>
        </div>
        <div class="lg:col-span-7 lg:pt-6">
          <p class="text-[15px] text-[var(--color-text-sub)] leading-loose">
            主要ブランドの公開買取実績から3社以上の実数値をクロスチェックして算出した、エルメス・シャネル・ロレックス等を含む12モデルの参考相場です。
            <span class="text-xs block mt-2">集計期間：{rateMetadata.collectionPeriod} ／ 更新：{rateMetadata.updatedAt}</span>
          </p>
        </div>
      </div>

      <!-- 主要ブランド最低買取保証額（Story から移動） -->
      <div class="mb-14 reveal">
        <div class="border border-[var(--color-border)] bg-[var(--color-bg)] p-6 md:p-8">
          <div class="flex items-baseline justify-between mb-5 pb-3 border-b border-[var(--color-border)]">
            <div class="eyebrow">主要ブランドの最低買取保証額</div>
            <div class="text-[10px] text-[var(--color-text-sub)] tracking-widest hidden sm:block">Minimum Guaranteed Buyback</div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-y-5 gap-x-4">
            {buybackGuarantees.map((g, i) => (
              <div class={`text-center sm:text-left ${i === buybackGuarantees.length - 1 ? "col-span-2 sm:col-span-1 border-t border-[var(--color-border)] pt-4 sm:border-0 sm:pt-0" : ""}`}>
                <div class="font-serif text-[var(--color-text)]">{g.brand}</div>
                <div class="text-[10px] text-[var(--color-text-sub)] mb-2">{g.jpName}</div>
                <div class="font-sans tabular-nums text-lg text-[var(--color-text)]" style="color: var(--color-accent-soft);">¥{g.minPrice.toLocaleString()}〜</div>
              </div>
            ))}
          </div>
          <p class="text-[11px] text-[var(--color-text-sub)] mt-5 leading-relaxed">
            ※ 正規品確認後、状態問わず最低買取保証額をお約束します。詳細条件はお問い合わせください。
          </p>
        </div>
      </div>

      {[
        { id: "bag", label: "バッグ", items: bagRates },
        { id: "watch", label: "時計", items: watchRates },
