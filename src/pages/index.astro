  <section id="contact" class="section-pad bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="text-center mb-14 reveal">
        <div class="eyebrow mb-4">名古屋ブランド買取のご相談</div>
        <h2 class="display-2 max-w-2xl mx-auto" aria-label="名古屋ブランド買取のご相談｜出張買取・LINE査定・宅配買取・お電話・フォームでお気軽に">
          まずは、お気軽に。
        </h2>
        <p class="text-[15px] text-[var(--color-text-sub)] mt-6">
          9:00-21:00 ／ 年中無休
        </p>
      </div>

      <div class="grid lg:grid-cols-12 gap-10">
        <!-- 左：3つの連絡手段 -->
        <div class="lg:col-span-5 reveal">
          <div class="space-y-4">
            <a href={phoneTel} class="card-min flex items-center gap-5 hover:border-[var(--color-text)] transition group">
              <div class="text-[10px] tracking-widest uppercase text-[var(--color-text-sub)] shrink-0">By Phone</div>
              <div class="flex-1">
                <div class="font-serif text-xl numeric tracking-wider text-[var(--color-text)]">{company.phone}</div>
                <div class="text-[11px] text-[var(--color-text-sub)] mt-1">9:00〜21:00 年中無休</div>
              </div>
              <span class="text-[var(--color-text)] text-lg">→</span>
            </a>

            <a href={lineUrl} target="_blank" rel="noopener" class="card-min flex items-center gap-5 hover:border-[var(--color-line)] transition group" style="border-color: var(--color-line);">
              <div class="text-[10px] tracking-widest uppercase text-[var(--color-line)] shrink-0">LINE</div>
              <div class="flex-1">
                <div class="font-serif text-xl text-[var(--color-text)]">公式LINEで査定</div>
                <div class="text-[11px] text-[var(--color-text-sub)] mt-1">最短15分・写真と型番だけ</div>
              </div>
              <span class="text-[var(--color-line)] text-lg">→</span>
            </a>

            <a href={`mailto:${contactEmail}`} class="card-min flex items-center gap-5 hover:border-[var(--color-text)] transition group">
              <div class="text-[10px] tracking-widest uppercase text-[var(--color-text-sub)] shrink-0">By Email</div>
              <div class="flex-1">
                <div class="font-serif text-[15px] sm:text-base text-[var(--color-text)] tracking-tight">{contactEmail}</div>
                <div class="text-[11px] text-[var(--color-text-sub)] mt-1">24時間受付・営業時間内に返信</div>
              </div>
              <span class="text-[var(--color-text)] text-lg">→</span>
            </a>
          </div>

          <div class="mt-8 grid grid-cols-2 gap-3">
            {[
              { label: "出張料", value: "無料" },
              { label: "査定料", value: "無料" },
              { label: "送料", value: "無料" },
              { label: "キャンセル料", value: "無料" },
            ].map((f) => (
              <div class="text-center p-4 bg-[var(--color-bg-2)]">
                <div class="text-[10px] tracking-widest uppercase text-[var(--color-text-sub)]">{f.label}</div>
                <div class="font-serif text-xl text-[var(--color-text)] mt-1">{f.value}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- 右：問い合わせフォーム -->
        <div class="lg:col-span-7 reveal reveal-delay-1">
          <form
            id="contact-form"
            action={formAction}
            method="POST"
            class="bg-[var(--color-bg)] border border-[var(--color-border)] p-6 sm:p-10"
            novalidate
          >
            <input type="hidden" name="_subject" value="徳丸商会 ブランド買取 お問い合わせ" />
            <input type="hidden" name="_template" value="table" />
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-5000px;" aria-hidden="true" />

            <div class="mb-6">
              <label for="f-name" class="form-label form-required">お名前</label>
              <input id="f-name" type="text" name="お名前" required minlength="2" placeholder="徳丸 太郎" autocomplete="name" class="form-input" />
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-2">
              <div>
                <label for="f-phone" class="form-label">電話番号</label>
                <input id="f-phone" type="tel" name="電話番号" inputmode="tel" pattern="[0-9\-]+" placeholder="090-XXXX-XXXX" autocomplete="tel" class="form-input" />
              </div>
              <div>
                <label for="f-email" class="form-label">メールアドレス</label>
                <input id="f-email" type="email" name="メールアドレス" placeholder="your@email.com" autocomplete="email" class="form-input" />
              </div>
            </div>
            <p class="text-[11px] text-[var(--color-text-sub)] mb-6">※ 電話番号またはメールアドレスのいずれかをご記入ください</p>

            <div class="mb-6">
              <label class="form-label form-required">ご希望の連絡方法</label>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
                {["電話","LINE","メール","どれでもOK"].map((opt, i) => (
                  <label class="form-radio-card">
                    <input type="radio" name="希望連絡方法" value={opt} required={i===0} />
                    <span>{opt}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-6">
              <div>
                <label for="f-brand" class="form-label">ブランド名</label>
                <input id="f-brand" type="text" name="ブランド" placeholder="例：エルメス、ロレックス" class="form-input" />
              </div>
              <div>
                <label for="f-category" class="form-label">商品ジャンル</label>
                <select id="f-category" name="商品ジャンル" class="form-select">
                  <option value="">— お選びください —</option>
                  <option>ブランドバッグ</option>
                  <option>ブランド財布・小物</option>
                  <option>ブランド時計</option>
                  <option>ブランドジュエリー</option>
                  <option>ブランドアパレル</option>
                  <option>複数まとめて</option>
                  <option>その他</option>
                </select>
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-6">
              <div>
                <label for="f-condition" class="form-label">商品の状態</label>
                <select id="f-condition" name="状態" class="form-select">
                  <option value="">— お選びください —</option>
                  <option>新品・未使用</option>
                  <option>使用感少ない（極美品）</option>
                  <option>通常使用感あり</option>
                  <option>使用感強め</option>
                  <option>破損あり・状態不問</option>
                  <option>不明</option>
                </select>
              </div>
              <div>
                <label for="f-method" class="form-label form-required">買取方法</label>
                <select id="f-method" name="買取方法" required class="form-select">
                  <option value="">— お選びください —</option>
                  <option>出張買取（最短当日）</option>
                  <option>LINE査定</option>
                  <option>宅配買取</option>
                  <option>おすすめを提案してほしい</option>
                </select>
              </div>
            </div>

            <div class="mb-6">
              <label for="f-message" class="form-label">メッセージ</label>
              <textarea id="f-message" name="メッセージ" rows="4" placeholder="型番・購入時期・付属品の有無などをご記入ください。お写真はLINEまたはメール添付がスムーズです。" class="form-textarea"></textarea>
            </div>

            <div class="mb-8">
              <label class="flex items-start gap-2 text-xs text-[var(--color-text-sub)] leading-relaxed cursor-pointer">
                <input type="checkbox" name="プライバシー同意" required class="mt-0.5" />
