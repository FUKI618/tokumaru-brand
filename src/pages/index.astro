            <dt class="text-[10px] uppercase tracking-widest text-[var(--color-text-sub)] mt-1">古物商許可</dt>
            <dd>{company.licenseAuthority}<br />{company.license}</dd>
          </div>
          <div class="grid grid-cols-[8rem_1fr] gap-4 pt-2">
            <dt class="text-[10px] uppercase tracking-widest text-[var(--color-text-sub)] mt-1">対応エリア</dt>
            <dd class="text-xs leading-relaxed">名古屋市16区／{company.nearby.slice(0, 8).join("／")} ほか</dd>
          </div>
        </dl>
      </div>

      <!-- 主要対応エリア（地域SEO・h3でローカル検索流入を確保） -->
      <div class="mt-14 pt-10 border-t border-[var(--color-border)] reveal">
        <div class="flex items-center gap-3 mb-6">
          <span class="block w-8 h-px bg-[var(--color-border)]"></span>
          <span class="eyebrow">主要対応エリア — 名古屋市内</span>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-7">
          <div>
            <h3 class="font-serif text-base text-[var(--color-text)] mb-1.5">中村区</h3>
            <p class="text-[11px] text-[var(--color-text-sub)] leading-relaxed">名古屋市中村区のブランド買取。本社所在地・最短当日訪問。</p>
          </div>
          <div>
            <h3 class="font-serif text-base text-[var(--color-text)] mb-1.5">中区</h3>
            <p class="text-[11px] text-[var(--color-text-sub)] leading-relaxed">栄・大須・伏見エリアのブランド出張買取に対応。</p>
          </div>
          <div>
            <h3 class="font-serif text-base text-[var(--color-text)] mb-1.5">千種区</h3>
            <p class="text-[11px] text-[var(--color-text-sub)] leading-relaxed">覚王山・本山エリアのブランド品出張買取・LINE査定。</p>
          </div>
          <div>
            <h3 class="font-serif text-base text-[var(--color-text)] mb-1.5">名東区</h3>
            <p class="text-[11px] text-[var(--color-text-sub)] leading-relaxed">高針・上社エリアのブランド買取に出張対応。</p>
          </div>
        </div>
        <p class="text-[11px] text-[var(--color-text-sub)] mt-7 leading-relaxed">
          上記4区以外の名古屋市16区（千種・東・北・西・昭和・瑞穂・熱田・中川・港・南・守山・緑・天白）、および尾張・知多・西三河エリアにも出張買取で対応します。詳細は <a href={sectionPath("contact")} class="underline underline-offset-2 hover:text-[var(--color-text)]">お問い合わせ</a> ください。
        </p>
      </div>
