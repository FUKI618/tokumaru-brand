---
import Layout from "../layouts/Layout.astro";
import { company } from "../data/company";
import { flagshipBrands, popularBrands, buybackGuarantees } from "../data/brands";
import { faqs } from "../data/faq";
import { staff } from "../data/staff";
import { rateData, rateMetadata, channelData, speedData } from "../data/rates";
import { assetPath, sectionPath } from "../lib/site";

const title = "名古屋ブランド買取｜出張・LINE査定・宅配の徳丸商会";
const description = "名古屋市中村区の徳丸商会。エルメス・シャネル・ヴィトン・ロレックス・カルティエなど主要ブランドを高価買取。出張・LINE査定・宅配買取に対応、9:00〜21:00年中無休。電話052-990-3968で最短当日訪問。古物商許可第541042309800号。";

const phoneTel = `tel:${company.phoneTel}`;
const lineUrl = company.line;
const contactEmail = "kaitori@tokumarushokai.com";

// Formspree URL（Formspreeアカウント作成後、フォームIDをここに設定）
// 未設定時は mailto: にフォールバック
const FORMSPREE_FORM_ID = "meenapqb"; // 設定済み 2026-05-04
const formAction = FORMSPREE_FORM_ID
  ? `https://formspree.io/f/${FORMSPREE_FORM_ID}`
  : `mailto:${contactEmail}`;
const formMethod = FORMSPREE_FORM_ID ? "POST" : "POST"; // mailtoはGET/POSTどちらも動作
const formEnctype = FORMSPREE_FORM_ID ? "application/x-www-form-urlencoded" : "text/plain";

const bagsBrands = popularBrands.filter((b) => b.category === "bag");
const watchesBrands = popularBrands.filter((b) => b.category === "watch");
const jewelryBrands = popularBrands.filter((b) => b.category === "jewelry");
const apparelBrands = popularBrands.filter((b) => b.category === "apparel");

const buybackExamples = [
  { brand: "HERMES", item: "バーキン25 トゴ ヴェールヴェロン", price: 1950000, rank: "A", date: "2026.04" },
  { brand: "HERMES", item: "ケリー28 ブラック ゴールド金具", price: 2800000, rank: "AB", date: "2026.04" },
  { brand: "CHANEL", item: "マトラッセ ラージ チェーンショルダー", price: 320000, rank: "A", date: "2026.04" },
  { brand: "CHANEL", item: "ミニマトラッセ ピンク", price: 420000, rank: "S", date: "2026.04" },
  { brand: "LOUIS VUITTON", item: "オンザゴーPM モノグラム", price: 380000, rank: "A", date: "2026.04" },
  { brand: "LOUIS VUITTON", item: "ネヴァーフルMM ダミエ", price: 110000, rank: "B", date: "2026.04" },
  { brand: "ROLEX", item: "デイトナ 116500LN ホワイト", price: 5500000, rank: "S", date: "2026.04" },
  { brand: "ROLEX", item: "サブマリーナ 124060", price: 1850000, rank: "A", date: "2026.03" },
  { brand: "Cartier", item: "ラブリング K18WG #50", price: 180000, rank: "B", date: "2026.04" },
  { brand: "Cartier", item: "サントス ガルベMM W20012C4", price: 720000, rank: "A", date: "2026.03" },
  { brand: "VAN CLEEF & ARPELS", item: "ヴィンテージアルハンブラ ペンダント YG", price: 280000, rank: "AB", date: "2026.04" },
  { brand: "TIFFANY", item: "ソリティア ダイヤ Pt950 0.26ct", price: 145000, rank: "AB", date: "2026.04" },
];

const nagoyaAreas = company.areas;
const nearbyAreas = company.nearby;

const testimonials = [
  { initial: "M", name: "M様", area: "名古屋市中区", age: "60代女性", brand: "エルメス・シャネル", text: "母から相続したブランドバッグを処分するつもりが、エルメス バーキンが想像以上の高値で驚きました。出張で来ていただいたので、家にあった他のブランド品もまとめて査定してもらえました。" },
  { initial: "T", name: "T様", area: "名古屋市天白区", age: "40代女性", brand: "ロレックス", text: "夫が結婚前から持っていたロレックス サブマリーナを売却。LINE査定で大体の金額を教えてくれて、後日宅配で送りました。査定額がほぼ提示通りだったので安心して取引できました。" },
  { initial: "K", name: "K様", area: "名古屋市瑞穂区", age: "50代男性", brand: "ルイ・ヴィトン・カルティエ", text: "クローゼットに眠っていたヴィトンのバッグと、奥さんのカルティエのジュエリーを査定。21時まで営業されているので仕事帰りに電話できたのが助かりました。複数業者で見積もりを取り、こちらが一番高かったので即決しました。" },
];

// マーキー用の主要ブランド名（流れ表示）
const marqueeBrands = [
  "HERMÈS","CHANEL","LOUIS VUITTON","ROLEX","CARTIER","PATEK PHILIPPE","AUDEMARS PIGUET","TIFFANY & Co.","BVLGARI","VAN CLEEF & ARPELS","DIOR","GUCCI","PRADA","BOTTEGA VENETA","CELINE","FENDI",
];

// 章番号
const chapter = (n: string, label: string) => `${n}. ${label}`;
---

<Layout title={title} description={description}>

  <!-- ============== Header ============== -->
  <header class="fixed top-0 inset-x-0 z-40 border-b border-white/5 bg-[var(--color-navy)]/85 backdrop-blur-xl supports-[backdrop-filter]:bg-[var(--color-navy)]/65">
    <div class="max-w-[1600px] mx-auto px-5 sm:px-8 py-3.5 flex items-center justify-between gap-3">
      <a href={sectionPath("hero")} class="flex items-center gap-2.5 group" aria-label="徳丸商会 トップへ">
        <img src={assetPath("logo.svg")} alt="徳丸商会" class="h-8 sm:h-9 w-auto" width="36" height="36" />
        <div class="leading-tight text-white">
          <div class="text-[10px] tracking-[0.3em] text-[var(--color-champagne)] uppercase">Tokumaru</div>
          <div class="text-sm font-display tracking-wider">名古屋ブランド買取</div>
        </div>
      </a>
      <nav class="hidden lg:flex items-center gap-7 text-[13px]" aria-label="セクションナビ">
        <a href={sectionPath("flagship")} class="text-white/65 hover:text-[var(--color-champagne)] transition tracking-wider">主要ブランド</a>
        <a href={sectionPath("guarantee")} class="text-white/65 hover:text-[var(--color-champagne)] transition tracking-wider">最低買取保証</a>
        <a href={sectionPath("methods")} class="text-white/65 hover:text-[var(--color-champagne)] transition tracking-wider">買取方法</a>
        <a href={sectionPath("examples")} class="text-white/65 hover:text-[var(--color-champagne)] transition tracking-wider">買取実績</a>
        <a href={sectionPath("faq")} class="text-white/65 hover:text-[var(--color-champagne)] transition tracking-wider">FAQ</a>
        <a href={sectionPath("contact")} class="text-white/65 hover:text-[var(--color-champagne)] transition tracking-wider">お問い合わせ</a>
      </nav>
      <div class="flex items-center gap-2">
        <a href={phoneTel} class="hidden sm:flex items-center gap-2 px-3.5 py-2 rounded-full text-[13px] font-bold text-[var(--color-champagne-light)] border border-[var(--color-champagne)]/40 hover:bg-white/5 transition numeric">
          <span aria-hidden="true">📞</span><span>{company.phone}</span>
        </a>
        <a href={lineUrl} target="_blank" rel="noopener" class="px-3.5 py-2 rounded-full text-[13px] font-bold text-white bg-[var(--color-line)] hover:bg-[#05a648] transition">LINE査定</a>
      </div>
    </div>
  </header>

  <!-- ============== Hero（フルスクリーン） ============== -->
  <section id="hero" class="relative min-h-[100svh] flex items-center bg-[var(--color-navy)] text-[var(--color-text-on-dark)] overflow-hidden grain">

    <!-- 背景写真：高級ジュエリー店ブティック（AI生成・テキスト/ロゴなし） -->
    <picture class="absolute inset-0 w-full h-full block" aria-hidden="true">
      <source srcset={assetPath("images/hero/luxury-bg.webp")} type="image/webp" />
      <img src={assetPath("images/hero/luxury-bg.jpg")} alt="" class="absolute inset-0 w-full h-full object-cover object-center" loading="eager" fetchpriority="high" width="1920" height="1080" />
    </picture>

    <!-- ダークオーバーレイ（読みやすさ確保） -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: linear-gradient(110deg, rgba(10, 14, 31, 0.93) 0%, rgba(10, 14, 31, 0.78) 35%, rgba(10, 14, 31, 0.55) 100%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at top left, rgba(197, 165, 114, 0.18) 0%, transparent 45%), radial-gradient(ellipse at bottom right, rgba(107, 18, 48, 0.25) 0%, transparent 50%);"></div>

    <!-- 装飾SVG: 大型サークル -->
    <svg class="absolute -right-32 -top-24 w-[640px] h-[640px] opacity-20 pointer-events-none" viewBox="0 0 600 600" aria-hidden="true">
      <defs>
        <radialGradient id="g1" cx="50%" cy="50%">
          <stop offset="0%" stop-color="#c5a572" stop-opacity="0.55"/>
          <stop offset="100%" stop-color="#c5a572" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <circle cx="300" cy="300" r="290" fill="none" stroke="#c5a572" stroke-opacity="0.2" stroke-width="1"/>
      <circle cx="300" cy="300" r="240" fill="none" stroke="#c5a572" stroke-opacity="0.15" stroke-width="1"/>
      <circle cx="300" cy="300" r="190" fill="url(#g1)"/>
    </svg>

    <!-- 装飾: グリッドライン -->
    <div class="absolute inset-0 pointer-events-none opacity-[0.03]" aria-hidden="true" style="background-image: linear-gradient(90deg, white 1px, transparent 1px), linear-gradient(180deg, white 1px, transparent 1px); background-size: 80px 80px;"></div>

    <div class="relative max-w-[1600px] mx-auto px-5 sm:px-8 py-24 sm:py-32 w-full z-10">
      <!-- 上段：エイエンタイトル + バッジ -->
      <div class="flex flex-wrap items-center gap-3 mb-8 reveal">
        <div class="chapter-num text-[var(--color-champagne)]">— TOKUMARU SHOKAI</div>
        <span class="hidden sm:inline-block w-12 h-px bg-[var(--color-champagne)]/50"></span>
        <span class="text-[10px] tracking-[0.3em] uppercase text-white/45">Nagoya, Aichi · Since 1992</span>
      </div>

      <!-- メインコピー -->
      <div class="grid lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-8">
          <div class="text-[11px] tracking-[0.5em] text-[var(--color-champagne)] mb-5 reveal">LUXURY BUYBACK · ESTABLISHED IN AICHI</div>

          <h1 class="mb-6" aria-label="名古屋でブランド品の買取なら徳丸商会｜エルメス・シャネル・ヴィトン・ロレックス・カルティエを高価買取">
            <!-- 日本語メインキャッチ（display-hero級・3秒で何の店か即理解） -->
            <span class="font-display font-medium block tracking-tight leading-[1.1] text-white reveal" style="font-size: clamp(2.2rem, 6.4vw, 5.4rem);">
              <span class="block">名古屋で</span>
              <span class="block text-gradient-champagne">ブランド品の買取</span>
              <span class="block">なら徳丸商会</span>
            </span>
            <!-- 英語サブキャッチ（副題として上品に） -->
            <span class="block mt-5 text-[11px] sm:text-xs tracking-[0.4em] uppercase text-[var(--color-champagne)]/85 italic font-display">— Sell your luxury, at its true value.</span>
          </h1>

          <div class="flex flex-wrap gap-2.5 mb-6 reveal">
            <span class="px-3 py-1.5 rounded-full text-[10px] tracking-wider font-semibold bg-[var(--color-champagne)]/15 border border-[var(--color-champagne)]/35 text-[var(--color-champagne-light)]">5ブランド最低買取保証</span>
            <span class="px-3 py-1.5 rounded-full text-[10px] tracking-wider font-semibold bg-white/5 border border-white/15">出張・LINE・宅配 完全無料</span>
            <span class="px-3 py-1.5 rounded-full text-[10px] tracking-wider font-semibold bg-[var(--color-bordeaux)]/30 border border-[var(--color-bordeaux-light)]/40 text-[var(--color-champagne-light)]">夜21時まで／年中無休</span>
          </div>

          <p class="text-sm sm:text-base max-w-2xl text-white/75 leading-loose reveal">
            最短15分でLINE査定。即日訪問の出張買取、送料・キット・キャンセル料すべて無料の宅配買取。<br class="hidden sm:block" />
            エルメス・シャネル・ヴィトン・ロレックス・カルティエの<strong class="text-[var(--color-champagne-light)]">5ブランドは最低買取保証額を明示</strong>、業界平均より3時間長い9-21時年中無休でご相談を承ります。
          </p>
        </div>

        <!-- 右カラム：CTAブロック -->
        <div class="lg:col-span-4 reveal">
          <div class="rounded-2xl border border-[var(--color-champagne)]/35 bg-white/5 backdrop-blur-md p-6 shadow-2xl">
            <div class="text-[10px] tracking-[0.4em] text-[var(--color-champagne)] uppercase mb-4">Get a quote now</div>
            <a href={lineUrl} target="_blank" rel="noopener" data-magnetic="0.25" class="cta-glow-line block w-full text-center py-4 rounded-xl bg-[var(--color-line)] text-white font-bold text-base mb-3 hover:bg-[#05a648] transition">
              <div class="text-[11px] tracking-wider opacity-90">最短15分で参考買取額</div>
              <div class="text-lg">LINEで無料査定</div>
            </a>
            <a href={phoneTel} data-magnetic="0.25" class="cta-glow-tel block w-full text-center py-4 rounded-xl bg-[var(--color-champagne)] text-[var(--color-navy)] font-bold mb-3 hover:bg-[var(--color-champagne-light)] transition">
              <div class="text-[11px] tracking-wider opacity-80">今すぐお電話</div>
              <div class="text-lg numeric">{company.phone}</div>
            </a>
            <a href={sectionPath("contact")} class="block w-full text-center py-3 rounded-xl border border-white/20 text-white/85 font-semibold text-sm hover:border-[var(--color-champagne)]/50 hover:bg-white/5 transition">
              フォームでお問い合わせ →
            </a>
            <div class="grid grid-cols-2 gap-2 mt-4 pt-4 border-t border-white/10 text-center">
              <div><div class="text-[10px] text-white/45">出張・査定・送料</div><div class="text-sm font-bold text-[var(--color-champagne-light)]">完全無料</div></div>
              <div><div class="text-[10px] text-white/45">クーリングオフ</div><div class="text-sm font-bold text-[var(--color-champagne-light)]">8日間対応</div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- 下段：比較バー（カウントアップアニメ付き） -->
      <div class="mt-14 grid grid-cols-3 gap-3 sm:gap-5 max-w-4xl reveal">
        <div class="rounded-xl px-4 py-3 sm:py-4 border border-white/10 bg-white/5 backdrop-blur">
          <div class="text-[10px] tracking-wider text-white/45 uppercase">業界平均営業時間</div>
          <div class="text-2xl sm:text-3xl font-display numeric text-white/40"><span data-counter="9">0</span><span class="text-xs ml-1">時間</span></div>
        </div>
        <div class="rounded-xl px-4 py-3 sm:py-4 border-2 border-[var(--color-champagne)] bg-[var(--color-champagne)]/15 backdrop-blur relative overflow-hidden">
          <div class="text-[10px] tracking-wider text-[var(--color-champagne)] uppercase font-bold">徳丸商会</div>
          <div class="text-2xl sm:text-3xl font-display numeric text-[var(--color-champagne-glow)]"><span data-counter="12">0</span><span class="text-xs ml-1">時間</span></div>
          <div class="text-[10px] text-white/55 mt-0.5">9-21時 年中無休</div>
        </div>
        <div class="rounded-xl px-4 py-3 sm:py-4 border border-white/10 bg-white/5 backdrop-blur">
          <div class="text-[10px] tracking-wider text-white/45 uppercase">最低買取保証</div>
          <div class="text-xl sm:text-2xl font-display text-[var(--color-champagne-light)]">業界唯一</div>
          <div class="text-[10px] text-white/55 mt-0.5">5ブランド明示</div>
        </div>
      </div>
    </div>

    <!-- 下端ブランドマーキー -->
    <div class="absolute bottom-0 inset-x-0 border-t border-white/10 bg-[var(--color-navy-mid)]/70 backdrop-blur py-4 marquee-mask overflow-hidden no-print">
      <div class="marquee-track">
        {[...marqueeBrands, ...marqueeBrands].map((b) => (
          <span class="font-display text-base sm:text-lg tracking-[0.2em] text-white/40 whitespace-nowrap">{b}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== I. 主要ブランド5強 ============== -->
  <section id="flagship" class="py-24 sm:py-32 bg-[var(--color-bg-white)] relative overflow-hidden">
    <!-- 背景: ベルベット&ジュエリー（AI生成） -->
    <picture class="absolute inset-0 w-full h-full block pointer-events-none" aria-hidden="true">
      <source srcset={assetPath("images/sections/flagship-velvet.webp")} type="image/webp" />
      <img src={assetPath("images/sections/flagship-velvet.jpg")} alt="" class="absolute inset-0 w-full h-full object-cover object-center opacity-100" loading="lazy" width="1920" height="1080" />
    </picture>
    <!-- 軽オーバーレイ（画像を主役に・カード自体が白なので読みやすさはカード内で確保） -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: linear-gradient(180deg, rgba(255,255,255,0.30) 0%, rgba(250,250,247,0.45) 100%);"></div>

    <div class="max-w-[1600px] mx-auto px-5 sm:px-8 relative z-10">
      <div class="grid lg:grid-cols-12 gap-10 mb-14 reveal">
        <div class="lg:col-span-5">
          <div class="chapter-num mb-4">Ⅰ. 主要ブランド</div>
          <h2 class="display-md text-[var(--color-navy)] heading-rule">
            エルメス・シャネル・ヴィトンを<br />高価買取
          </h2>
        </div>
        <div class="lg:col-span-7 lg:pt-10">
          <p class="text-[15px] text-[var(--color-text-light)] leading-loose max-w-2xl">
            全国の競合10社を徹底調査した上で、ブランド別の<strong class="text-[var(--color-bordeaux)]">最低買取保証額</strong>を明示しています。バッグ・時計・ジュエリーのいずれも、状態不問で適正価格をお約束します。
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {flagshipBrands.map((b, i) => (
          <article class="reveal card-luxury bg-white rounded-2xl border border-[var(--color-border)] overflow-hidden" data-tilt>
            <div class="px-7 py-6 bg-[var(--color-navy)] text-white relative overflow-hidden">
              <div class="font-display text-2xl tracking-[0.18em] relative">{b.name}</div>
              <div class="text-xs text-[var(--color-champagne-light)] tracking-wider relative">{b.jpName}</div>
            </div>
            <div class="px-7 py-6">
              <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-champagne-dark)] mb-3">Popular Models</div>
              <ul class="text-[13px] text-[var(--color-text)] grid grid-cols-2 gap-y-1.5 mb-5">
                {b.popularModels.slice(0, 6).map((m) => (
                  <li class="flex items-center gap-1.5 leading-snug">
                    <span class="text-[var(--color-champagne)]" aria-hidden="true">▸</span>{m}
                  </li>
                ))}
              </ul>
              {b.example && (
                <div class="text-xs text-[var(--color-text-light)] bg-gradient-to-br from-[var(--color-cream)] to-white rounded-lg px-4 py-3 leading-relaxed border border-[var(--color-border)]">
                  <span class="font-bold text-[var(--color-bordeaux)]">買取例：</span>{b.example}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== II. 最低買取保証 ============== -->
  <section id="guarantee" class="py-24 sm:py-32 bg-[var(--color-navy)] text-white relative overflow-hidden grain">
    <!-- 背景: 金庫の扉（AI生成） -->
    <picture class="absolute inset-0 w-full h-full block" aria-hidden="true">
      <source srcset={assetPath("images/sections/guarantee-vault.webp")} type="image/webp" />
      <img src={assetPath("images/sections/guarantee-vault.jpg")} alt="" class="absolute inset-0 w-full h-full object-cover object-center opacity-90" loading="lazy" width="1920" height="1080" />
    </picture>
    <!-- 軽めのダークオーバーレイ（画像を主役に） -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: linear-gradient(180deg, rgba(10,14,31,0.35) 0%, rgba(10,14,31,0.55) 100%);"></div>

    <svg class="absolute left-0 top-0 w-[400px] opacity-15 pointer-events-none z-[1]" viewBox="0 0 400 400" aria-hidden="true">
      <circle cx="0" cy="200" r="280" fill="none" stroke="#c5a572" stroke-width="0.5"/>
      <circle cx="0" cy="200" r="220" fill="none" stroke="#c5a572" stroke-width="0.5"/>
    </svg>

    <div class="max-w-[1600px] mx-auto px-5 sm:px-8 relative">
      <div class="text-center mb-16 reveal">
        <div class="chapter-num mb-4">Ⅱ. 価格保証</div>
        <h2 class="display-md heading-rule center inline-block">主要ブランド最低買取保証額</h2>
        <p class="mt-7 text-[15px] text-white/70 max-w-3xl mx-auto leading-loose">
          全国の競合10社中、最低買取保証を明示しているのは<strong class="text-[var(--color-champagne-light)]">わずか1社（10%）</strong>。<br class="hidden sm:block" />
          徳丸商会は5ブランドで保証額をお約束し、状態不問で買取いたします。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 stagger-children">
        {buybackGuarantees.map((g, idx) => (
          <div class="reveal guarantee-card text-[var(--color-text)] rounded-xl p-6 text-center">
            <div class="font-display text-xl tracking-[0.15em] text-[var(--color-navy)] relative">{g.brand}</div>
