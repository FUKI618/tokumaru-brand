            novalidate
          >
            <input type="hidden" name="_subject" value="徳丸商会 ブランド買取 お問い合わせ" />
            <input type="hidden" name="_template" value="table" />
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-5000px;" aria-hidden="true" />

            <div class="mb-5">
              <label for="f-name" class="form-label form-label-required">お名前</label>
              <input id="f-name" type="text" name="お名前" required minlength="2" placeholder="徳丸 太郎" autocomplete="name" class="form-input" />
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-2">
              <div>
                <label for="f-phone" class="form-label">電話番号</label>
                <input id="f-phone" type="tel" name="電話番号" inputmode="tel" pattern="[0-9\-]+" placeholder="090-XXXX-XXXX" autocomplete="tel" class="form-input" />
              </div>
              <div>
                <label for="f-email" class="form-label">メールアドレス</label>
                <input id="f-email" type="email" name="メールアドレス" placeholder="your@email.com" autocomplete="email" class="form-input" />
              </div>
            </div>
            <p class="text-[11px] text-[var(--color-text-light)] mb-5">※ 電話番号またはメールアドレスのいずれかをご記入ください</p>

            <div class="mb-5">
              <label class="form-label form-label-required">ご希望の連絡方法</label>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
                {["電話","LINE","メール","どれでもOK"].map((opt, i) => (
                  <label class="form-radio-card">
                    <input type="radio" name="希望連絡方法" value={opt} required={i===0} />
                    <span>{opt}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-5">
              <div>
                <label for="f-brand" class="form-label">ブランド名（複数可）</label>
                <input id="f-brand" type="text" name="ブランド" placeholder="例：エルメス、ロレックス、シャネル" class="form-input" />
              </div>
              <div>
                <label for="f-category" class="form-label">商品ジャンル</label>
                <select id="f-category" name="商品ジャンル" class="form-select">
                  <option value="">— お選びください —</option>
                  <option>ブランドバッグ</option>
                  <option>ブランド財布・小物</option>
                  <option>ブランド時計</option>
                  <option>ブランドジュエリー</option>
                  <option>ブランドアパレル</option>
                  <option>複数まとめて</option>
                  <option>その他</option>
                </select>
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-5">
              <div>
                <label for="f-condition" class="form-label">商品の状態</label>
                <select id="f-condition" name="状態" class="form-select">
                  <option value="">— お選びください —</option>
                  <option>新品・未使用</option>
                  <option>使用感少ない（極美品）</option>
                  <option>通常使用感あり</option>
                  <option>使用感強め</option>
                  <option>破損あり・状態不問</option>
                  <option>不明</option>
                </select>
              </div>
              <div>
                <label for="f-method" class="form-label form-label-required">買取方法のご希望</label>
                <select id="f-method" name="買取方法" required class="form-select">
                  <option value="">— お選びください —</option>
                  <option>出張買取（最短当日）</option>
                  <option>LINE査定</option>
                  <option>宅配買取</option>
                  <option>おすすめを提案してほしい</option>
                </select>
              </div>
            </div>

            <div class="mb-5">
              <label for="f-area" class="form-label">お住まいエリア（出張買取の場合）</label>
              <input id="f-area" type="text" name="エリア" placeholder="例：名古屋市中区、刈谷市など" class="form-input" />
            </div>

            <div class="mb-5">
              <label for="f-message" class="form-label">メッセージ・ご質問</label>
              <textarea id="f-message" name="メッセージ" rows="4" placeholder="型番、購入時期、付属品の有無などをご記入ください。お写真はLINEまたはメール添付でお送りいただくとスムーズです。" class="form-textarea"></textarea>
            </div>

            <div class="mb-6">
              <label class="flex items-start gap-2 text-xs text-[var(--color-text-light)] leading-relaxed">
                <input type="checkbox" name="プライバシー同意" required class="mt-0.5" />
                <span>個人情報の取り扱いについて理解し同意します。お送りいただいた内容は買取査定のためにのみ使用します。</span>
              </label>
            </div>

            <button type="submit" class="w-full py-4 rounded-xl bg-[var(--color-navy)] text-white font-bold tracking-wider hover:bg-[var(--color-navy-mid)] transition flex items-center justify-center gap-2">
              <span>査定を依頼する</span>
              <span class="text-[var(--color-champagne-glow)]">→</span>
            </button>

            <p class="mt-4 text-[11px] text-[var(--color-text-lighter)] leading-relaxed text-center">
              送信後、24時間以内に営業担当よりご連絡いたします（営業時間: 9:00-21:00 年中無休）。<br />
              フォーム送信ができない場合は <a href={`mailto:${contactEmail}`} class="underline text-[var(--color-bordeaux)]">{contactEmail}</a> へ直接お送りください。
            </p>
          </form>

          <!-- 送信成功表示（クライアントサイドJSで切替） -->
          <div id="contact-thanks" hidden class="rounded-2xl bg-white/95 text-[var(--color-text)] p-8 backdrop-blur border border-[var(--color-champagne)] shadow-2xl text-center">
            <div class="w-14 h-14 rounded-full bg-[var(--color-champagne)] text-[var(--color-navy)] mx-auto flex items-center justify-center text-2xl mb-4">✓</div>
            <h3 class="font-display text-2xl text-[var(--color-navy)] mb-2">お問い合わせありがとうございます</h3>
            <p class="text-sm text-[var(--color-text-light)] leading-loose">担当より24時間以内にご連絡いたします。<br />お急ぎの方は <a href={phoneTel} class="text-[var(--color-bordeaux)] underline">052-990-3968</a> まで。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Footer ============== -->
  <footer class="bg-[var(--color-navy)] text-white/85 pt-16 pb-10 text-sm relative overflow-hidden">
    <div class="absolute inset-0 grain-light pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-[1600px] mx-auto px-5 sm:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
        <div>
          <div class="flex items-center gap-2.5 mb-4">
            <img src={assetPath("logo.svg")} alt="徳丸商会" class="h-9 w-auto" width="40" height="40" />
            <div>
              <div class="text-[10px] tracking-[0.3em] text-[var(--color-champagne)] uppercase">Tokumaru</div>
              <div class="font-display text-lg text-white">徳丸商会</div>
            </div>
          </div>
          <p class="text-xs leading-loose text-white/65">
            名古屋市中村区横井の古物商。ブランドバッグ・時計・ジュエリー・アパレル・財布の買取専門。出張買取・LINE査定・宅配買取に対応します。
          </p>
        </div>
        <div>
          <h4 class="font-display text-base text-[var(--color-champagne-light)] mb-4 chapter-num">Store Info</h4>
          <dl class="text-xs leading-loose text-white/75 space-y-1.5">
            <div class="flex gap-2"><dt class="w-16 shrink-0 text-white/55">所在地</dt><dd>{company.address.full}</dd></div>
            <div class="flex gap-2"><dt class="w-16 shrink-0 text-white/55">電話</dt><dd class="numeric">{company.phone}</dd></div>
            <div class="flex gap-2"><dt class="w-16 shrink-0 text-white/55">メール</dt><dd class="break-all">{contactEmail}</dd></div>
            <div class="flex gap-2"><dt class="w-16 shrink-0 text-white/55">営業時間</dt><dd>{company.hours}</dd></div>
            <div class="flex gap-2"><dt class="w-16 shrink-0 text-white/55">許可</dt><dd>{company.licenseAuthority} {company.license}</dd></div>
          </dl>
        </div>
        <div>
          <h4 class="font-display text-base text-[var(--color-champagne-light)] mb-4 chapter-num">Services</h4>
          <ul class="text-xs leading-loose text-white/75 space-y-1.5 mb-5">
            <li><a href={sectionPath("methods")} class="hover:text-[var(--color-champagne-light)] transition">出張買取・LINE査定・宅配買取</a></li>
            <li><a href={sectionPath("flagship")} class="hover:text-[var(--color-champagne-light)] transition">主要ブランド5強の買取</a></li>
            <li><a href={sectionPath("guarantee")} class="hover:text-[var(--color-champagne-light)] transition">最低買取保証額</a></li>
            <li><a href={sectionPath("areas")} class="hover:text-[var(--color-champagne-light)] transition">対応エリア</a></li>
            <li><a href={sectionPath("faq")} class="hover:text-[var(--color-champagne-light)] transition">よくあるご質問</a></li>
            <li><a href={sectionPath("contact")} class="hover:text-[var(--color-champagne-light)] transition">お問い合わせフォーム</a></li>
          </ul>
          <h4 class="font-display text-base text-[var(--color-champagne-light)] mb-3 chapter-num">Sister LPs</h4>
          <ul class="text-xs leading-loose text-white/75 space-y-1.5">
            <li><a href={company.relatedLps.estate} target="_blank" rel="noopener" class="hover:text-[var(--color-champagne-light)] transition">遺品整理・生前整理</a></li>
          </ul>
        </div>
      </div>
      <div class="divider-champagne mb-6"></div>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-[10px] text-white/55">
        <p>© 2026 徳丸商会 All Rights Reserved.</p>
        <p class="tracking-wider">愛知県公安委員会許可 第541042309800号</p>
      </div>
    </div>
  </footer>

  <!-- ============== Mobile Floating CTA ============== -->
  <div class="fixed bottom-0 left-0 right-0 z-50 md:hidden floating-cta-shadow no-print bg-[var(--color-navy)]/95 backdrop-blur border-t border-[var(--color-champagne)]/30">
    <div class="grid grid-cols-2 gap-2 p-2">
      <a href={phoneTel} class="flex flex-col items-center justify-center py-2.5 rounded-lg bg-[var(--color-champagne)] text-[var(--color-navy)] font-bold">
        <span class="text-[9px] tracking-wider">電話で相談</span>
        <span class="text-xs numeric">{company.phone}</span>
      </a>
      <a href={lineUrl} target="_blank" rel="noopener" class="flex flex-col items-center justify-center py-2.5 rounded-lg bg-[var(--color-line)] text-white font-bold">
        <span class="text-[9px] tracking-wider">最短15分で査定</span>
        <span class="text-xs">LINEで査定</span>
      </a>
    </div>
  </div>

  <!-- フォーム送信時の体験向上スクリプト -->
  <script is:inline>
    (function(){
      var form = document.getElementById('contact-form');
      var thanks = document.getElementById('contact-thanks');
      if (!form || !thanks) return;

      // 電話・メールのどちらか必須を検証
      function validateContact() {
        var phone = (form.querySelector('input[name="電話番号"]') || {}).value || '';
        var email = (form.querySelector('input[name="メールアドレス"]') || {}).value || '';
        if (!phone.trim() && !email.trim()) {
          alert('電話番号またはメールアドレスのいずれかをご記入ください。');
          return false;
        }
        return true;
      }

      var action = form.getAttribute('action') || '';
      if (action.indexOf('mailto:') === 0) {
        // mailto モード
        form.addEventListener('submit', function(e){
          if (!validateContact()) { e.preventDefault(); return; }
          setTimeout(function(){
            form.hidden = true;
            thanks.hidden = false;
            thanks.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 600);
        });
      } else {
        // Formspree モード（非同期送信）
        form.addEventListener('submit', async function(e){
          e.preventDefault();
          if (!validateContact()) return;
          var fd = new FormData(form);
          try {
            var res = await fetch(action, { method: 'POST', body: fd, headers: { 'Accept': 'application/json' } });
            if (res.ok) {
              form.hidden = true;
              thanks.hidden = false;
              thanks.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else {
              alert('送信に失敗しました。お電話またはメールで直接ご連絡ください。');
            }
          } catch(err) {
            alert('送信に失敗しました。お電話またはメールで直接ご連絡ください。');
          }
        });
      }
    })();
  </script>

</Layout>
