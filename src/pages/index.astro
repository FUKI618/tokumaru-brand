            <li><a href={sectionPath("methods")} class="hover:opacity-100 opacity-75 transition">3つのご利用方法</a></li>
            <li><a href={sectionPath("campaigns")} class="hover:opacity-100 opacity-75 transition">キャンペーン</a></li>
            <li><a href={sectionPath("staff")} class="hover:opacity-100 opacity-75 transition">査定員紹介</a></li>
