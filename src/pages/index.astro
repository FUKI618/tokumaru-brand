            <div class="rounded-xl p-3 border border-[var(--color-champagne)]/20 bg-white/5"><div class="text-[10px] text-white/55">査定料</div><div class="font-display text-lg text-[var(--color-champagne-light)]">¥0</div></div>
            <div class="rounded-xl p-3 border border-[var(--color-champagne)]/20 bg-white/5"><div class="text-[10px] text-white/55">送料</div><div class="font-display text-lg text-[var(--color-champagne-light)]">¥0</div></div>
