---
import Layout from "../layouts/Layout.astro";
import { company } from "../data/company";
import { flagshipBrands, popularBrands, buybackGuarantees } from "../data/brands";
import { faqs } from "../data/faq";
import { staff } from "../data/staff";
import { rateData, rateMetadata } from "../data/rates";
import { campaigns } from "../data/campaigns";
import { voices } from "../data/voices";
import { assetPath, sectionPath } from "../lib/site";

const title = "名古屋ブランド買取｜出張・LINE査定・宅配の徳丸商会【夜21時まで】";
const description = "名古屋市中村区の徳丸商会。エルメス・シャネル・ヴィトン・ロレックス・カルティエなど主要ブランドを高価買取。相続・形見整理に丁寧に対応。出張・LINE・宅配対応、9-21時年中無休。電話052-990-3968。古物商許可第541042309800号。";

const phoneTel = `tel:${company.phoneTel}`;
const lineUrl = company.line;
const contactEmail = "kaitori@tokumarushokai.com";

// Formspree（meenapqb 設定済み）
const FORMSPREE_FORM_ID = "meenapqb";
const formAction = FORMSPREE_FORM_ID
  ? `https://formspree.io/f/${FORMSPREE_FORM_ID}`
  : `mailto:${contactEmail}`;

// ブランドカテゴリ
const bagsBrands = popularBrands.filter((b) => b.category === "bag");
const watchesBrands = popularBrands.filter((b) => b.category === "watch");
const jewelryBrands = popularBrands.filter((b) => b.category === "jewelry");
const apparelBrands = popularBrands.filter((b) => b.category === "apparel");

// rates カテゴリ別
const bagRates = rateData.filter((r) => r.category === "bag");
const watchRates = rateData.filter((r) => r.category === "watch");
const jewelryRates = rateData.filter((r) => r.category === "jewelry");
---

<Layout title={title} description={description}>

  <!-- ============== Header ============== -->
  <header class="fixed top-0 inset-x-0 z-40 bg-[var(--color-bg)]/85 backdrop-blur-md border-b border-[var(--color-border)]">
    <div class="container-content flex items-center justify-between py-4">
      <a href={sectionPath("hero")} class="flex items-center gap-2.5" aria-label="徳丸商会 トップへ">
        <img src={assetPath("logo.svg")} alt="徳丸商会" class="h-8 w-auto" width="36" height="36" />
        <div class="leading-tight">
          <div class="text-[10px] tracking-[0.25em] text-[var(--color-text-sub)] uppercase">Tokumaru Shokai</div>
          <div class="text-sm font-serif text-[var(--color-text)]">名古屋ブランド買取</div>
        </div>
      </a>
      <nav class="hidden lg:flex items-center gap-7 text-[13px]" aria-label="セクションナビ">
        <a href={sectionPath("story")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">買取の姿勢</a>
        <a href={sectionPath("rates")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">参考買取相場</a>
        <a href={sectionPath("methods")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">買取方法</a>
        <a href={sectionPath("campaigns")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">キャンペーン</a>
        <a href={sectionPath("faq")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">FAQ</a>
        <a href={sectionPath("contact")} class="text-[var(--color-text-sub)] hover:text-[var(--color-text)] transition">お問い合わせ</a>
      </nav>
      <div class="hidden md:flex items-center gap-2">
        <a href={phoneTel} class="text-[13px] font-medium text-[var(--color-text)] hover:text-[var(--color-accent-soft)] transition numeric tracking-wider">
          {company.phone}
        </a>
        <a href={lineUrl} target="_blank" rel="noopener" class="btn btn-line btn-sm">LINEで査定</a>
      </div>
    </div>
  </header>

  <!-- ============== 1. Hero ============== -->
  <section id="hero" class="relative min-h-[80svh] md:min-h-[90vh] flex items-end overflow-hidden bg-[var(--color-bg-2)] grain-soft">

    <!-- 背景画像（既存をフィルター付きで使用、暖色オフホワイトに馴染ませる） -->
    <picture class="absolute inset-0 w-full h-full block" aria-hidden="true">
      <source srcset={assetPath("images/hero/luxury-bg.webp")} type="image/webp" />
      <img src={assetPath("images/hero/luxury-bg.jpg")} alt="" class="absolute inset-0 w-full h-full object-cover object-center opacity-60" loading="eager" fetchpriority="high" width="1920" height="1080" style="filter: brightness(1.1) saturate(0.6) hue-rotate(-10deg);" />
    </picture>
    <div class="absolute inset-0 hero-overlay" aria-hidden="true"></div>

    <div class="container-content relative w-full pt-24 pb-16 md:pt-32 md:pb-20">
      <div class="grid lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-8 reveal">
          <div class="eyebrow mb-6">— Nagoya, since 1992</div>
          <h1 class="display-1 mb-6 max-w-3xl" aria-label="名古屋でブランド品の買取なら徳丸商会｜エルメス・シャネル・ヴィトン・ロレックス・カルティエを高価買取">
            <span class="block">価値が分かる店で、</span>
            <span class="block italic font-serif" style="color: var(--color-accent-soft);">手放す。</span>
          </h1>
          <p class="text-base md:text-lg text-[var(--color-text-sub)] leading-loose max-w-xl mb-8">
            名古屋でブランド品の買取なら徳丸商会へ。<br />
            エルメス・シャネル・ヴィトン・ロレックス・カルティエ。<br />
            親から受け継いだ品も、長く眠っていた品も、<wbr />一点ずつ丁寧に拝見します。
          </p>
        </div>

        <div class="lg:col-span-4 reveal reveal-delay-1">
          <div class="flex flex-col gap-3">
            <a href={lineUrl} target="_blank" rel="noopener" class="btn btn-line btn-lg w-full">
              LINEで無料査定
            </a>
            <a href={phoneTel} class="btn btn-primary btn-lg w-full">
              <span class="numeric tracking-wider">{company.phone}</span>
            </a>
            <a href={sectionPath("contact")} class="btn btn-outline w-full">
              フォームから相談
            </a>
            <p class="text-xs text-[var(--color-text-sub)] text-center mt-2 leading-relaxed">
              出張料・査定料・キャンセル料 すべて0円<br />
              9:00-21:00 年中無休
            </p>
          </div>
        </div>
      </div>
    </div>

  </section>

  <!-- ============== 2. Story（コア訴求） ============== -->
  <section id="story" class="section-pad bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-5 reveal">
          <div class="eyebrow mb-4">私たちの姿勢</div>
          <h2 class="display-2 mb-8">
            他店で値が付かなかった品も、<br />丁寧に拝見します。
          </h2>
          <p class="text-base text-[var(--color-text-sub)] leading-loose">
            「もう古いから」「使用感があるから」「保証書がないから」——<br />
            そんな理由で諦めたお品を、もう一度お持ちいただきたいのです。
          </p>
        </div>

        <div class="lg:col-span-7 space-y-8">
          <div class="reveal reveal-delay-1">
            <div class="quote-mark text-base text-[var(--color-text)] leading-loose font-serif italic">
              <p class="not-italic font-sans text-[var(--color-text-sub)] mb-4">{staff[1].surname}（{staff[1].role}）</p>
              <p>{staff[1].message}</p>
              <p class="mt-6 not-italic text-sm font-medium text-[var(--color-text)]">— {staff[1].policy}</p>
            </div>
          </div>

          <hr class="divider reveal" />

          <div class="reveal reveal-delay-2">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-3 text-sm">
              {[
                "保証書なし",
                "箱・付属品なし",
                "使用感あり",
                "小さな破れ",
                "金具のくすみ",
                "メッキ剥がれ",
                "不動の時計",
                "経年劣化",
              ].map((c) => (
                <div class="flex items-baseline gap-2 py-1 border-b border-[var(--color-border)]">
                  <span class="text-[var(--color-accent-soft)] text-xs">○</span>
                  <span class="text-[var(--color-text-sub)]">{c}</span>
                </div>
              ))}
            </div>
            <p class="text-xs text-[var(--color-text-sub)] mt-4">いずれの状態でも、まずは一度ご相談ください。</p>
          </div>

          <hr class="divider reveal" />

          <!-- 主要ブランド5強の保証額 -->
          <div class="reveal reveal-delay-3">
            <div class="eyebrow mb-3">主要ブランドの最低買取保証額</div>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mt-4">
              {buybackGuarantees.map((g) => (
                <div class="text-center md:text-left">
                  <div class="font-serif text-[var(--color-text)]">{g.brand}</div>
                  <div class="text-[10px] text-[var(--color-text-sub)] mb-2">{g.jpName}</div>
                  <div class="font-serif text-lg italic numeric" style="color: var(--color-accent-soft);">¥{g.minPrice.toLocaleString()}〜</div>
                </div>
              ))}
            </div>
            <p class="text-[11px] text-[var(--color-text-sub)] mt-4 leading-relaxed">
              ※ 正規品確認後、状態問わず最低買取保証額をお約束します。詳細条件はお問い合わせください。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== 3. Rates（参考買取相場） ============== -->
  <section id="rates" class="section-pad bg-[var(--color-bg-2)]">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-8 mb-12 reveal">
        <div class="lg:col-span-5">
          <div class="eyebrow mb-4">主要ブランドの参考買取相場</div>
          <h2 class="display-2">12モデルの<br />買取目安レンジ</h2>
        </div>
        <div class="lg:col-span-7 lg:pt-6">
          <p class="text-[15px] text-[var(--color-text-sub)] leading-loose">
            業界の公開公式相場・買取実績ページから3社以上の実数値をクロスチェックして算出した、業界の参考買取相場レンジ。
            <span class="text-xs block mt-2">集計期間：{rateMetadata.collectionPeriod} ／ 更新：{rateMetadata.updatedAt}</span>
          </p>
        </div>
      </div>

      {[
        { id: "bag", label: "バッグ", items: bagRates },
        { id: "watch", label: "時計", items: watchRates },
        { id: "jewelry", label: "ジュエリー", items: jewelryRates },
      ].map((cat) => (
        <div class="mb-12 reveal">
          <div class="flex items-end justify-between mb-6 pb-3 border-b border-[var(--color-border)]">
            <h3 class="font-serif text-xl text-[var(--color-text)]">{cat.label}</h3>
            <div class="text-xs text-[var(--color-text-sub)] numeric tracking-wider">{cat.items.length} models</div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
            {cat.items.map((r) => (
              <article class="py-1">
                <div class="flex items-baseline justify-between mb-1.5">
                  <div class="font-serif text-[var(--color-text)] tracking-wide">{r.brand}</div>
                  <div class="text-[10px] text-[var(--color-text-sub)] tracking-widest">×{r.sources}社調査</div>
                </div>
                <div class="text-sm text-[var(--color-text)] mb-3 font-medium">{r.model}</div>
                {r.variant && <div class="text-[11px] text-[var(--color-text-sub)] mb-3">{r.variant}</div>}
                <div class="space-y-1.5 pt-2 border-t border-[var(--color-border)]">
                  <div class="flex items-baseline justify-between text-sm">
                    <span class="text-[10px] text-[var(--color-text-sub)] uppercase tracking-wider">最低</span>
                    <span class="numeric text-[var(--color-text-sub)]">¥{r.min.toLocaleString()}〜</span>
                  </div>
                  <div class="flex items-baseline justify-between text-sm">
                    <span class="text-[10px] text-[var(--color-accent-soft)] uppercase tracking-wider font-medium">中央値</span>
                    <span class="font-serif text-base numeric" style="color: var(--color-accent-soft);">{r.midLabel}</span>
                  </div>
                  <div class="flex items-baseline justify-between text-sm">
                    <span class="text-[10px] text-[var(--color-text-sub)] uppercase tracking-wider">最高</span>
                    <span class="numeric text-[var(--color-text-sub)]">〜¥{r.max.toLocaleString()}</span>
                  </div>
                </div>
                {r.note && (
                  <p class="text-[10px] text-[var(--color-text-sub)] mt-3 leading-relaxed">{r.note}</p>
                )}
              </article>
            ))}
          </div>
        </div>
      ))}

      <p class="text-xs text-[var(--color-text-sub)] mt-8 max-w-3xl leading-relaxed">
        ※ {rateMetadata.disclaimer}<br />
        ※ 「最低相場」=中古状態・付属品なしを含む最低帯／「中央値」=出現データの中位帯（推定の単一数値ではありません）／「最高相場」=新品・未使用品・人気色のプレミアム上限。
      </p>
    </div>
  </section>

  <!-- ============== 4. Methods（3つのご利用方法） ============== -->
  <section id="methods" class="section-pad bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="text-center mb-14 reveal">
        <div class="eyebrow mb-4">3つのご利用方法</div>
        <h2 class="display-2 max-w-2xl mx-auto">
          ご都合の良い方法を、お選びください。
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <article class="card-min reveal">
          <div class="eyebrow mb-3">Visit</div>
          <h3 class="display-3 mb-3">出張買取</h3>
          <div class="text-xs text-[var(--color-accent-soft)] mb-5 tracking-wider">最短当日訪問・出張料0円</div>
          <ul class="text-sm text-[var(--color-text-sub)] space-y-2 leading-relaxed mb-6">
            <li>名古屋市16区＋尾張・知多・西三河</li>
            <li>査定員が一般車両で訪問</li>
            <li>ご自宅で査定→現金即支払い</li>
            <li>クーリングオフ8日間対応</li>
          </ul>
          <a href={phoneTel} class="btn btn-outline btn-sm w-full">電話で予約する</a>
        </article>

        <article class="card-min reveal reveal-delay-1" style="border-color: var(--color-accent-soft);">
          <div class="flex items-center gap-2 mb-3">
            <div class="eyebrow eyebrow-accent">LINE</div>
            <div class="text-[9px] tracking-widest uppercase text-[var(--color-bg)] bg-[var(--color-accent-soft)] px-2 py-0.5">人気</div>
          </div>
          <h3 class="display-3 mb-3">LINE査定</h3>
          <div class="text-xs text-[var(--color-accent-soft)] mb-5 tracking-wider">最短15分で参考買取額</div>
          <ul class="text-sm text-[var(--color-text-sub)] space-y-2 leading-relaxed mb-6">
            <li>24時間受付・営業時間内に返信</li>
            <li>写真と型番を送るだけ</li>
            <li>来店・出張前の事前見積に最適</li>
            <li>公式LINE登録のみで利用可能</li>
          </ul>
          <a href={lineUrl} target="_blank" rel="noopener" class="btn btn-line btn-sm w-full">LINEで査定する</a>
        </article>

        <article class="card-min reveal reveal-delay-2">
          <div class="eyebrow mb-3">Mail</div>
          <h3 class="display-3 mb-3">宅配買取</h3>
          <div class="text-xs text-[var(--color-accent-soft)] mb-5 tracking-wider">送料・キット代・返送料すべて無料</div>
          <ul class="text-sm text-[var(--color-text-sub)] space-y-2 leading-relaxed mb-6">
            <li>全国対応（離島除く）</li>
            <li>専用ダンボール無料お届け</li>
            <li>最大5,000万円の運送保険付き</li>
            <li>査定後、最短当日銀行振込</li>
          </ul>
          <a href={phoneTel} class="btn btn-outline btn-sm w-full">宅配キットを申込</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============== 5. Campaigns（新規） ============== -->
  <section id="campaigns" class="section-pad bg-[var(--color-bg-3)]">
    <div class="container-content">
      <div class="text-center mb-14 reveal">
        <div class="eyebrow eyebrow-accent mb-4">期間限定 ＋ 常設特典</div>
        <h2 class="display-2 max-w-2xl mx-auto">
          ご利用いただきやすい、3つのキャンペーン。
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {campaigns.map((c, i) => (
          <article class={`card-min reveal reveal-delay-${i + 1}`}>
            <div class="flex items-center justify-between mb-4">
              <div class="text-[10px] tracking-[0.2em] uppercase text-[var(--color-bg)] bg-[var(--color-text)] px-2.5 py-1">{c.badge}</div>
              {c.period && <div class="text-[10px] text-[var(--color-text-sub)] tracking-wider">{c.period}</div>}
            </div>
            <h3 class="display-3 mb-2">{c.title}</h3>
            <p class="text-sm text-[var(--color-accent-soft)] mb-4 font-medium leading-relaxed">{c.subtitle}</p>
            <p class="text-sm text-[var(--color-text-sub)] mb-5 leading-relaxed">{c.description}</p>
            <ul class="text-xs text-[var(--color-text-sub)] space-y-1.5 mb-6 pl-3 border-l border-[var(--color-border)]">
              {c.bullets.map((b) => (<li>・{b}</li>))}
            </ul>
            {c.ctaTarget === "line" && (
              <a href={lineUrl} target="_blank" rel="noopener" class="btn btn-outline btn-sm w-full">{c.ctaLabel}</a>
            )}
            {c.ctaTarget === "phone" && (
              <a href={phoneTel} class="btn btn-outline btn-sm w-full">{c.ctaLabel}</a>
            )}
            {c.ctaTarget === "form" && (
              <a href={sectionPath("contact")} class="btn btn-outline btn-sm w-full">{c.ctaLabel}</a>
            )}
            <p class="text-[10px] text-[var(--color-text-mute)] mt-4 leading-relaxed">{c.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 6. Staff（査定員紹介） ============== -->
  <section id="staff" class="section-pad bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="text-center mb-14 reveal">
        <div class="eyebrow mb-4">査定を担当する2人</div>
        <h2 class="display-2 max-w-2xl mx-auto">
          顔の見える、査定。
        </h2>
        <p class="text-[15px] text-[var(--color-text-sub)] mt-6 max-w-2xl mx-auto leading-loose">
          ご来店・ご訪問時に実際に査定を担当する2名の専門スタッフです。<br />
          それぞれが得意分野を持ち、根拠に基づいた査定をお約束します。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {staff.map((s, i) => (
          <article class={`reveal reveal-delay-${i + 1}`}>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-14 h-14 rounded-full bg-[var(--color-text)] text-[var(--color-bg)] flex items-center justify-center font-serif text-xl shrink-0">{s.initial}</div>
              <div>
                <div class="font-serif text-2xl text-[var(--color-text)]">{s.surname}</div>
                <div class="text-[10px] tracking-[0.2em] uppercase text-[var(--color-text-sub)] mt-0.5">{s.surnameKana} ／ {s.role}</div>
              </div>
            </div>
            <div class="flex flex-wrap gap-2 mb-6">
              {s.specialty.map((sp) => (<span class="chip">{sp}</span>))}
            </div>
            <div class="quote-mark">
              <p class="text-sm text-[var(--color-text)] leading-loose">{s.message}</p>
            </div>
            <div class="mt-6 pt-6 border-t border-[var(--color-border)]">
              <div class="eyebrow eyebrow-accent mb-2">信条</div>
              <p class="font-serif italic text-base text-[var(--color-text)]">{s.policy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 7. Voices（お客様の声） ============== -->
  <section id="voices" class="section-pad bg-[var(--color-bg-2)]">
    <div class="container-content">
      <div class="text-center mb-14 reveal">
        <div class="eyebrow mb-4">お客様からの言葉</div>
        <h2 class="display-2 max-w-2xl mx-auto">
          相続・形見整理、<br />断捨離のご利用から。
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {voices.map((v, i) => (
          <article class={`reveal reveal-delay-${i + 1}`}>
            <div class="flex items-baseline gap-3 mb-5">
              <div class="font-serif text-3xl text-[var(--color-accent-soft)]">{v.initial}</div>
              <div class="text-xs text-[var(--color-text-sub)]">
                <div>{v.age} ／ {v.area}</div>
                <div class="mt-0.5">{v.context}</div>
              </div>
            </div>
            <div class="quote-mark">
              <p class="text-sm text-[var(--color-text)] leading-loose mb-6">{v.quote}</p>
            </div>
            <p class="text-sm font-serif italic text-[var(--color-text)] pt-5 border-t border-[var(--color-border)]">— {v.insight}</p>
            <p class="text-[10px] text-[var(--color-text-sub)] mt-3 tracking-wider">{v.brandsKnown}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 8. FAQ ============== -->
  <section id="faq" class="section-pad bg-[var(--color-bg)]">
    <div class="container-narrow">
      <div class="text-center mb-12 reveal">
        <div class="eyebrow mb-4">よくあるご質問</div>
        <h2 class="display-2">
          ご利用前のご不安に、お答えします。
        </h2>
      </div>

      <div class="space-y-2">
        {faqs.map((f) => (
          <details id={f.id} class="faq-item group border-t border-[var(--color-border)]">
            <summary class="flex items-center justify-between py-5 cursor-pointer hover:bg-[var(--color-bg-2)] transition px-2 -mx-2">
              <h3 class="text-[15px] font-medium text-[var(--color-text)] pr-4 leading-snug">{f.question}</h3>
              <span class="faq-icon flex-shrink-0 w-6 h-6 border border-[var(--color-text)] flex items-center justify-center text-base font-serif" aria-hidden="true">＋</span>
            </summary>
            <div class="px-2 pb-6 text-sm text-[var(--color-text-sub)] leading-loose">{f.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 9. Info（会社情報・控えめに） ============== -->
  <section id="info" class="section-pad-sm bg-[var(--color-bg-2)]">
    <div class="container-content">
      <div class="grid md:grid-cols-2 gap-10 items-start reveal">
        <div>
          <div class="eyebrow mb-3">徳丸商会について</div>
          <h2 class="display-2 mb-6">古物商として、<br />名古屋から。</h2>
          <p class="text-sm text-[var(--color-text-sub)] leading-loose">
            徳丸商会は、愛知県公安委員会許可（第541042309800号）を取得した古物商です。<br class="hidden md:block" />
            名古屋市中村区横井に拠点を置き、名古屋市内および尾張・知多・西三河エリアを中心に、ブランド品の出張買取・LINE査定・宅配買取を行っています。
          </p>
        </div>

        <dl class="text-sm text-[var(--color-text)] space-y-3 leading-relaxed">
          <div class="grid grid-cols-[8rem_1fr] gap-4 pb-3 border-b border-[var(--color-border)]">
            <dt class="text-[10px] uppercase tracking-widest text-[var(--color-text-sub)] mt-1">所在地</dt>
            <dd>{company.address.full}</dd>
          </div>
          <div class="grid grid-cols-[8rem_1fr] gap-4 pb-3 border-b border-[var(--color-border)]">
            <dt class="text-[10px] uppercase tracking-widest text-[var(--color-text-sub)] mt-1">電話</dt>
            <dd class="numeric">{company.phone}</dd>
          </div>
          <div class="grid grid-cols-[8rem_1fr] gap-4 pb-3 border-b border-[var(--color-border)]">
            <dt class="text-[10px] uppercase tracking-widest text-[var(--color-text-sub)] mt-1">メール</dt>
            <dd class="break-all">{contactEmail}</dd>
          </div>
          <div class="grid grid-cols-[8rem_1fr] gap-4 pb-3 border-b border-[var(--color-border)]">
            <dt class="text-[10px] uppercase tracking-widest text-[var(--color-text-sub)] mt-1">営業時間</dt>
            <dd>{company.hours}</dd>
          </div>
          <div class="grid grid-cols-[8rem_1fr] gap-4 pb-3 border-b border-[var(--color-border)]">
            <dt class="text-[10px] uppercase tracking-widest text-[var(--color-text-sub)] mt-1">古物商許可</dt>
            <dd>{company.licenseAuthority}<br />{company.license}</dd>
          </div>
          <div class="grid grid-cols-[8rem_1fr] gap-4 pt-2">
            <dt class="text-[10px] uppercase tracking-widest text-[var(--color-text-sub)] mt-1">対応エリア</dt>
            <dd class="text-xs leading-relaxed">名古屋市16区／{company.nearby.slice(0, 8).join("／")} ほか</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- ============== 10. Contact（お問い合わせ） ============== -->
  <section id="contact" class="section-pad bg-[var(--color-bg)]">
    <div class="container-content">
      <div class="text-center mb-14 reveal">
        <div class="eyebrow mb-4">お問い合わせ</div>
        <h2 class="display-2 max-w-2xl mx-auto">
          まずは、お気軽に。
        </h2>
        <p class="text-[15px] text-[var(--color-text-sub)] mt-6">
          9:00-21:00 ／ 年中無休
        </p>
      </div>

      <div class="grid lg:grid-cols-12 gap-10">
        <!-- 左：3つの連絡手段 -->
        <div class="lg:col-span-5 reveal">
          <div class="space-y-4">
            <a href={phoneTel} class="card-min flex items-center gap-5 hover:border-[var(--color-text)] transition group">
              <div class="text-[10px] tracking-widest uppercase text-[var(--color-text-sub)] shrink-0">By Phone</div>
              <div class="flex-1">
                <div class="font-serif text-xl numeric tracking-wider text-[var(--color-text)]">{company.phone}</div>
                <div class="text-[11px] text-[var(--color-text-sub)] mt-1">9:00〜21:00 年中無休</div>
              </div>
              <span class="text-[var(--color-text)] text-lg">→</span>
            </a>

            <a href={lineUrl} target="_blank" rel="noopener" class="card-min flex items-center gap-5 hover:border-[var(--color-line)] transition group" style="border-color: var(--color-line);">
              <div class="text-[10px] tracking-widest uppercase text-[var(--color-line)] shrink-0">LINE</div>
              <div class="flex-1">
                <div class="font-serif text-xl text-[var(--color-text)]">公式LINEで査定</div>
                <div class="text-[11px] text-[var(--color-text-sub)] mt-1">最短15分・写真と型番だけ</div>
              </div>
              <span class="text-[var(--color-line)] text-lg">→</span>
            </a>

            <a href={`mailto:${contactEmail}`} class="card-min flex items-center gap-5 hover:border-[var(--color-text)] transition group">
              <div class="text-[10px] tracking-widest uppercase text-[var(--color-text-sub)] shrink-0">By Email</div>
              <div class="flex-1">
                <div class="font-serif text-base text-[var(--color-text)] break-all">{contactEmail}</div>
                <div class="text-[11px] text-[var(--color-text-sub)] mt-1">24時間受付・営業時間内に返信</div>
              </div>
              <span class="text-[var(--color-text)] text-lg">→</span>
            </a>
          </div>

          <div class="mt-8 grid grid-cols-2 gap-3">
            {[
              { label: "出張料", value: "¥0" },
              { label: "査定料", value: "¥0" },
              { label: "送料", value: "¥0" },
              { label: "キャンセル料", value: "¥0" },
            ].map((f) => (
              <div class="text-center p-4 bg-[var(--color-bg-2)]">
                <div class="text-[10px] tracking-widest uppercase text-[var(--color-text-sub)]">{f.label}</div>
                <div class="font-serif text-xl text-[var(--color-text)] mt-1">{f.value}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- 右：問い合わせフォーム -->
        <div class="lg:col-span-7 reveal reveal-delay-1">
          <form
            id="contact-form"
            action={formAction}
            method="POST"
            class="bg-[var(--color-bg)] border border-[var(--color-border)] p-6 sm:p-10"
            novalidate
          >
            <input type="hidden" name="_subject" value="徳丸商会 ブランド買取 お問い合わせ" />
            <input type="hidden" name="_template" value="table" />
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-5000px;" aria-hidden="true" />

            <div class="mb-6">
              <label for="f-name" class="form-label form-required">お名前</label>
              <input id="f-name" type="text" name="お名前" required minlength="2" placeholder="徳丸 太郎" autocomplete="name" class="form-input" />
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-2">
              <div>
                <label for="f-phone" class="form-label">電話番号</label>
                <input id="f-phone" type="tel" name="電話番号" inputmode="tel" pattern="[0-9\-]+" placeholder="090-XXXX-XXXX" autocomplete="tel" class="form-input" />
              </div>
              <div>
                <label for="f-email" class="form-label">メールアドレス</label>
                <input id="f-email" type="email" name="メールアドレス" placeholder="your@email.com" autocomplete="email" class="form-input" />
              </div>
            </div>
            <p class="text-[11px] text-[var(--color-text-sub)] mb-6">※ 電話番号またはメールアドレスのいずれかをご記入ください</p>

            <div class="mb-6">
              <label class="form-label form-required">ご希望の連絡方法</label>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
                {["電話","LINE","メール","どれでもOK"].map((opt, i) => (
                  <label class="form-radio-card">
                    <input type="radio" name="希望連絡方法" value={opt} required={i===0} />
                    <span>{opt}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-6">
              <div>
                <label for="f-brand" class="form-label">ブランド名</label>
                <input id="f-brand" type="text" name="ブランド" placeholder="例：エルメス、ロレックス" class="form-input" />
              </div>
              <div>
                <label for="f-category" class="form-label">商品ジャンル</label>
                <select id="f-category" name="商品ジャンル" class="form-select">
                  <option value="">— お選びください —</option>
                  <option>ブランドバッグ</option>
                  <option>ブランド財布・小物</option>
                  <option>ブランド時計</option>
                  <option>ブランドジュエリー</option>
                  <option>ブランドアパレル</option>
                  <option>複数まとめて</option>
                  <option>その他</option>
                </select>
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-6">
              <div>
                <label for="f-condition" class="form-label">商品の状態</label>
                <select id="f-condition" name="状態" class="form-select">
                  <option value="">— お選びください —</option>
                  <option>新品・未使用</option>
                  <option>使用感少ない（極美品）</option>
                  <option>通常使用感あり</option>
                  <option>使用感強め</option>
                  <option>破損あり・状態不問</option>
                  <option>不明</option>
                </select>
              </div>
              <div>
                <label for="f-method" class="form-label form-required">買取方法</label>
                <select id="f-method" name="買取方法" required class="form-select">
                  <option value="">— お選びください —</option>
                  <option>出張買取（最短当日）</option>
                  <option>LINE査定</option>
                  <option>宅配買取</option>
                  <option>おすすめを提案してほしい</option>
                </select>
              </div>
            </div>

            <div class="mb-6">
              <label for="f-message" class="form-label">メッセージ</label>
              <textarea id="f-message" name="メッセージ" rows="4" placeholder="型番・購入時期・付属品の有無などをご記入ください。お写真はLINEまたはメール添付がスムーズです。" class="form-textarea"></textarea>
            </div>

            <div class="mb-8">
              <label class="flex items-start gap-2 text-xs text-[var(--color-text-sub)] leading-relaxed cursor-pointer">
                <input type="checkbox" name="プライバシー同意" required class="mt-0.5" />
                <span>個人情報の取り扱いについて理解し同意します。お送りいただいた内容は買取査定のためにのみ使用します。</span>
              </label>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-full">
              査定を依頼する
            </button>

            <p class="mt-5 text-[11px] text-[var(--color-text-sub)] leading-relaxed text-center">
              送信後、24時間以内に営業担当よりご連絡いたします（営業: 9:00-21:00 年中無休）。<br />
              フォーム送信が困難な場合は <a href={`mailto:${contactEmail}`} class="underline">{contactEmail}</a> へ直接お送りください。
            </p>
          </form>

          <!-- サンクス -->
          <div id="contact-thanks" hidden class="bg-[var(--color-bg-2)] border border-[var(--color-accent-soft)] p-10 text-center">
            <div class="eyebrow eyebrow-accent mb-4">Thank you</div>
            <h3 class="display-2 mb-3">お問い合わせありがとうございます</h3>
            <p class="text-sm text-[var(--color-text-sub)] leading-loose">担当より24時間以内にご連絡いたします。<br />お急ぎの方は <a href={phoneTel} class="underline">{company.phone}</a> まで。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Footer ============== -->
  <footer class="section-pad-sm bg-[var(--color-bg-dark)] text-[var(--color-bg)]">
    <div class="container-content">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
        <div>
          <div class="flex items-center gap-2.5 mb-4">
            <img src={assetPath("logo.svg")} alt="徳丸商会" class="h-8 w-auto invert" width="36" height="36" />
            <div>
              <div class="text-[10px] tracking-[0.25em] uppercase opacity-60">Tokumaru Shokai</div>
              <div class="font-serif text-base">徳丸商会</div>
            </div>
          </div>
          <p class="text-xs leading-loose opacity-65">
            名古屋市中村区横井の古物商。ブランドバッグ・時計・ジュエリー・アパレル・財布の買取専門。出張買取・LINE査定・宅配買取に対応。
          </p>
        </div>
        <div>
          <h4 class="text-[10px] tracking-[0.25em] uppercase opacity-60 mb-4">店舗情報</h4>
          <dl class="text-xs leading-relaxed space-y-1.5">
            <div><dt class="inline opacity-50 mr-2">所在地</dt><dd class="inline">{company.address.full}</dd></div>
            <div><dt class="inline opacity-50 mr-2">電話</dt><dd class="inline numeric">{company.phone}</dd></div>
            <div><dt class="inline opacity-50 mr-2">メール</dt><dd class="inline break-all">{contactEmail}</dd></div>
            <div><dt class="inline opacity-50 mr-2">営業時間</dt><dd class="inline">{company.hours}</dd></div>
            <div><dt class="inline opacity-50 mr-2">許可</dt><dd class="inline">{company.licenseAuthority} {company.license}</dd></div>
          </dl>
        </div>
        <div>
          <h4 class="text-[10px] tracking-[0.25em] uppercase opacity-60 mb-4">サイト内リンク</h4>
          <ul class="text-xs leading-relaxed space-y-1.5">
            <li><a href={sectionPath("story")} class="hover:opacity-100 opacity-75 transition">買取の姿勢</a></li>
            <li><a href={sectionPath("rates")} class="hover:opacity-100 opacity-75 transition">参考買取相場</a></li>
            <li><a href={sectionPath("methods")} class="hover:opacity-100 opacity-75 transition">3つのご利用方法</a></li>
            <li><a href={sectionPath("campaigns")} class="hover:opacity-100 opacity-75 transition">キャンペーン</a></li>
            <li><a href={sectionPath("staff")} class="hover:opacity-100 opacity-75 transition">査定員紹介</a></li>
            <li><a href={sectionPath("voices")} class="hover:opacity-100 opacity-75 transition">お客様の声</a></li>
            <li><a href={sectionPath("faq")} class="hover:opacity-100 opacity-75 transition">よくあるご質問</a></li>
            <li><a href={sectionPath("contact")} class="hover:opacity-100 opacity-75 transition">お問い合わせ</a></li>
          </ul>
          <h4 class="text-[10px] tracking-[0.25em] uppercase opacity-60 mb-2 mt-5">姉妹サービス</h4>
          <ul class="text-xs leading-relaxed space-y-1.5">
            <li><a href={company.relatedLps.estate} target="_blank" rel="noopener" class="hover:opacity-100 opacity-75 transition">遺品整理・生前整理</a></li>
          </ul>
        </div>
      </div>

      <hr class="border-0 border-t border-white/10 mb-5" />

      <div class="flex flex-col md:flex-row items-center justify-between gap-3 text-[10px] opacity-55">
        <p>© 2026 徳丸商会 All Rights Reserved.</p>
        <p class="tracking-wider">愛知県公安委員会許可 第541042309800号</p>
      </div>
    </div>
  </footer>

  <!-- ============== Mobile Sticky CTA ============== -->
  <div class="mobile-cta no-print">
    <div class="grid grid-cols-2 gap-2 p-2">
      <a href={phoneTel} class="btn btn-outline btn-sm w-full">
        <span class="numeric text-xs">{company.phone}</span>
      </a>
      <a href={lineUrl} target="_blank" rel="noopener" class="btn btn-line btn-sm w-full">LINEで査定</a>
    </div>
  </div>

  <!-- フォーム送信制御 -->
  <script is:inline>
    (function(){
      var form = document.getElementById('contact-form');
      var thanks = document.getElementById('contact-thanks');
      if (!form || !thanks) return;

      function validateContact() {
        var phone = (form.querySelector('input[name="電話番号"]') || {}).value || '';
        var email = (form.querySelector('input[name="メールアドレス"]') || {}).value || '';
        if (!phone.trim() && !email.trim()) {
          alert('電話番号またはメールアドレスのいずれかをご記入ください。');
          return false;
        }
        return true;
      }

      var action = form.getAttribute('action') || '';
      if (action.indexOf('mailto:') === 0) {
        form.addEventListener('submit', function(e){
          if (!validateContact()) { e.preventDefault(); return; }
          setTimeout(function(){
            form.hidden = true;
            thanks.hidden = false;
            thanks.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 600);
        });
      } else {
        form.addEventListener('submit', async function(e){
          e.preventDefault();
          if (!validateContact()) return;
          var fd = new FormData(form);
          try {
            var res = await fetch(action, { method: 'POST', body: fd, headers: { 'Accept': 'application/json' } });
            if (res.ok) {
              form.hidden = true;
              thanks.hidden = false;
              thanks.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else {
              alert('送信に失敗しました。お電話またはメールで直接ご連絡ください。');
            }
          } catch(err) {
            alert('送信に失敗しました。お電話またはメールで直接ご連絡ください。');
          }
        });
      }
    })();
  </script>

</Layout>
