---
interface Props {
  title: string;
  description: string;
  extraJsonLd?: Record<string, unknown>[];
}

import "../styles/global.css";
import { assetPath, homePath } from "../lib/site";
import { faqsToJsonLd } from "../data/faq";
import { company } from "../data/company";
import { flagshipBrands } from "../data/brands";
import { staff } from "../data/staff";

const { title, description, extraJsonLd = [] } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL(homePath, siteUrl).toString();
const ogImage = new URL(assetPath("og-image.webp"), siteUrl).toString();
const faviconUrl = assetPath("favicon.svg");
const logoUrl = new URL(assetPath("logo.svg"), siteUrl).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="keywords" content="ブランド買取,名古屋,ブランドバッグ買取,ブランド時計買取,ブランドジュエリー買取,エルメス買取,シャネル買取,ルイヴィトン買取,ロレックス買取,カルティエ買取,出張買取,LINE査定,宅配買取,愛知県古物商,名古屋市中村区" />
    <meta name="theme-color" content="#1a1f3a" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://googleads.g.doubleclick.net https://www.google.com https://www.google-analytics.com https://www.googleadservices.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://www.google.com https://googleads.g.doubleclick.net https://www.googleadservices.com https://www.google-analytics.com https://www.google.co.jp; connect-src 'self' https://www.google-analytics.com https://www.google.com https://googleads.g.doubleclick.net https://analytics.google.com https://fonts.googleapis.com https://fonts.gstatic.com https://region1.google-analytics.com; frame-src https://www.googletagmanager.com https://googleads.g.doubleclick.net" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="徳丸商会｜名古屋のブランド買取。エルメス・シャネル・ヴィトン・ロレックス・カルティエを高価買取。" />
    <meta property="og:site_name" content="徳丸商会｜名古屋のブランド買取" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="徳丸商会｜名古屋のブランド買取。" />

    <!-- Fonts: 非同期読み込み（FOUT回避: display=swap） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      (function(){
        var l=document.createElement('link');l.rel='stylesheet';
        l.href='https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Cormorant+Garamond:wght@400;500;600&display=swap';
        document.head.appendChild(l);
      })();
    </script>

    <!-- Google Tag Manager: 3秒遅延（Core Web Vitals保護） -->
    <script is:inline>
      window.dataLayer=window.dataLayer||[];
      setTimeout(function(){
        (function(w,d,s,l,i){w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
        var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
        j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
        f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-W493L98W');
      },3000);
    </script>

    <!-- JSON-LD #1: LocalBusiness（@id 参照型・OfferCatalog 内蔵） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${homeUrl}#localbusiness`,
      "name": "徳丸商会",
      "alternateName": "徳丸商会 ブランド買取",
      "description": "名古屋市中村区横井の古物商。ブランドバッグ・時計・ジュエリー・アパレルを名古屋市内および尾張・知多・西三河エリアで出張買取・LINE査定・宅配買取。営業9:00〜21:00 年中無休。",
      "telephone": company.phone,
      "url": homeUrl,
      "image": ogImage,
      "logo": logoUrl,
      "priceRange": "¥¥¥",
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "09:00",
        "closes": "21:00"
      }],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "横井2丁目71番地",
        "addressLocality": "名古屋市中村区",
        "addressRegion": "愛知県",
        "postalCode": "453-0863",
        "addressCountry": "JP"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "35.1709",
        "longitude": "136.8815"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "telephone": company.phone,
        "availableLanguage": ["ja"],
        "areaServed": "JP",
        "hoursAvailable": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "09:00",
          "closes": "21:00"
        }
      },
      "areaServed": [
        { "@type": "City", "name": "名古屋市", "containedInPlace": { "@type": "State", "name": "愛知県" } },
        ...company.areas.map(area => ({ "@type": "AdministrativeArea", "name": `名古屋市${area}` })),
        ...company.nearby.map(city => ({ "@type": "City", "name": city, "containedInPlace": { "@type": "State", "name": "愛知県" } }))
      ],
      "sameAs": [company.line],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "ブランド買取サービス",
        "itemListElement": [
          {
            "@type": "OfferCatalog",
            "name": "買取方法",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "出張買取（名古屋市16区＋尾張・知多・西三河）", "serviceType": "出張買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "LINE査定（写真送信で参考買取額を提示）", "serviceType": "オンライン査定" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "宅配買取（送料・キット・返送料すべて無料）", "serviceType": "宅配買取" } }
            ]
          },
          {
            "@type": "OfferCatalog",
            "name": "取扱カテゴリ",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランドバッグ買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランド財布・小物買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランド時計買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランドジュエリー買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランドアパレル買取" } }
            ]
          },
          {
            "@type": "OfferCatalog",
            "name": "主要ブランド",
            "itemListElement": flagshipBrands.map((b) => ({
              "@type": "Offer",
              "itemOffered": { "@type": "Service", "name": `${b.jpName}（${b.name}）買取` }
            }))
          }
        ]
      }
    })} />

    <!-- JSON-LD #2: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "徳丸商会",
      "url": homeUrl,
      "logo": logoUrl,
      "telephone": company.phone,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "横井2丁目71番地",
        "addressLocality": "名古屋市中村区",
        "addressRegion": "愛知県",
        "postalCode": "453-0863",
        "addressCountry": "JP"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": company.phone,
        "contactType": "customer support",
        "availableLanguage": "ja",
        "areaServed": "JP"
      },
      "sameAs": [company.line]
    })} />

    <!-- JSON-LD #2.5: WebSite + SearchAction（検索ボックス表示の可能性） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": `${homeUrl}#website`,
      "name": "徳丸商会 ブランド買取",
      "alternateName": "Tokumaru Shokai Brand Buyback",
      "url": homeUrl,
      "publisher": { "@id": `${homeUrl}#localbusiness` },
      "inLanguage": "ja-JP",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${homeUrl}?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- JSON-LD #2.6: Service（独立した買取サービス3種） -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": `${homeUrl}#service-visit`,
        "serviceType": "出張買取",
        "name": "ブランド品の出張買取",
        "description": "名古屋市16区および尾張・知多・西三河エリアへ最短当日訪問。査定員がご自宅に伺い、その場で査定・現金支払い。出張料・査定料・キャンセル料すべて無料。クーリングオフ8日間対応。",
        "provider": { "@id": `${homeUrl}#localbusiness` },
        "areaServed": company.areas.map((a) => ({ "@type": "AdministrativeArea", "name": `名古屋市${a}` })),
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY", "description": "出張料・査定料・キャンセル料すべて無料" }
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": `${homeUrl}#service-line`,
        "serviceType": "オンライン査定",
        "name": "LINE査定（写真送信で参考買取額をご提示）",
        "description": "公式LINEに写真と型番を送るだけ。最短15分で参考買取額をご提示します。営業時間内 9:00〜21:00 年中無休で受付。",
        "provider": { "@id": `${homeUrl}#localbusiness` },
        "areaServed": "JP",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY" }
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": `${homeUrl}#service-mail`,
        "serviceType": "宅配買取",
        "name": "ブランド品の宅配買取",
        "description": "全国対応の宅配買取。専用ダンボールを無料お届け、送料・返送料すべて無料。最大5,000万円までの運送保険付き。査定後最短当日に銀行振込でお支払い。",
        "provider": { "@id": `${homeUrl}#localbusiness` },
        "areaServed": "JP",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY", "description": "送料・キット代・返送料すべて無料" }
      }
    ])} />

    <!-- JSON-LD #3: FAQPage（src/data/faq.ts より自動生成） -->
    <script type="application/ld+json" set:html={JSON.stringify(faqsToJsonLd())} />

    <!-- JSON-LD #4: HowTo（買取の流れ 3ステップ） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "名古屋でブランド品の買取を依頼する方法",
      "description": "徳丸商会のブランド買取サービスを利用する手順。電話またはLINEのお問い合わせから、出張買取・LINE査定・宅配買取いずれかをお選びいただき、現金または銀行振込でお支払いまでをご案内します。",
      "totalTime": "PT1H",
      "estimatedCost": { "@type": "MonetaryAmount", "currency": "JPY", "value": "0" },
      "tool": [
        { "@type": "HowToTool", "name": "本人確認書類（運転免許証・健康保険証＋住民票・パスポート等）" },
        { "@type": "HowToTool", "name": "買取希望のブランド品（保証書・箱・付属品があれば一緒に）" }
      ],
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "お電話・LINE・フォームでお問い合わせ",
          "text": "052-990-3968（9:00-21:00 年中無休）または公式LINEで、お持ちのブランド品の写真と型番をお送りください。LINEなら最短15分で参考買取額をご案内します。",
          "url": `${homeUrl}#contact`
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "出張買取・LINE査定・宅配買取からお選び",
          "text": "出張買取は名古屋市内最短当日訪問・出張料無料。宅配買取は宅配キット・送料・返送料すべて無料・最大5,000万円までの運送保険付き。LINE査定はその場で参考買取額を提示。",
          "url": `${homeUrl}#methods`
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "査定・現金または振込でお支払い",
          "text": "経験豊富な査定士が、ブランド・モデル・状態・付属品を確認のうえ買取金額をご提示。ご納得いただければ、出張買取は現金即支払い、宅配買取は最短当日振込でお支払いします。キャンセルもいつでも無料です。",
          "url": `${homeUrl}#flow`
        }
      ]
    })} />

    <!-- JSON-LD #4.5: Person（査定員2名のE-E-A-T強化） -->
    <script type="application/ld+json" set:html={JSON.stringify(
      staff.map((s) => ({
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": `${homeUrl}#staff-${s.surnameKana.toLowerCase()}`,
        "name": s.surname,
        "jobTitle": s.role,
        "worksFor": { "@id": `${homeUrl}#localbusiness` },
        "knowsAbout": s.specialty,
        "description": s.message,
      }))
    )} />

    <!-- JSON-LD #5: BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "ホーム",
          "item": homeUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "ブランド買取（名古屋）",
          "item": homeUrl
        }
      ]
    })} />

    {extraJsonLd.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body class="antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W493L98W"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <slot />

    <!-- Alpine.js（FAQアコーディオン他） -->
    <script>
      import Alpine from "alpinejs";
      window.Alpine = Alpine;
      Alpine.start();
    </script>

    <!-- 数千万LP級マイクロインタラクション: GSAP + Lenis + カスタムカーソル等 -->
    <script>
      import "../scripts/luxury-effects.ts";
    </script>
  </body>
</html>
