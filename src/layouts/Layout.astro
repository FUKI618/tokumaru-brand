---
interface Props {
  title: string;
  description: string;
  extraJsonLd?: Record<string, unknown>[];
}

import "../styles/global.css";
import { assetPath, homePath } from "../lib/site";
import { faqsToJsonLd } from "../data/faq";
import { company } from "../data/company";
import { flagshipBrands } from "../data/brands";
import { staff } from "../data/staff";
import { rateData } from "../data/rates";

const { title, description, extraJsonLd = [] } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL(homePath, siteUrl).toString();
const ogImage = new URL(assetPath("og-image.webp"), siteUrl).toString();
const faviconUrl = assetPath("favicon.svg");
const logoUrl = new URL(assetPath("logo.svg"), siteUrl).toString();

// Microsoft Clarity: PUBLIC_CLARITY_PROJECT_ID を .env に設定すると有効化
// pro-lp-launch L1.5 / pro-lp-ops W3.5 で活用
const clarityProjectId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="keywords" content="ブランド買取,名古屋ブランド買取,出張買取,LINE査定,宅配買取,ロレックス買取,エルメス買取,シャネル買取,ルイヴィトン買取,名古屋市中村区" />
    <meta name="theme-color" content="#fdfbf9" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://googleads.g.doubleclick.net https://www.google.com https://www.google-analytics.com https://www.googleadservices.com https://cdn.jsdelivr.net https://www.clarity.ms https://*.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://www.google.com https://googleads.g.doubleclick.net https://www.googleadservices.com https://www.google-analytics.com https://www.google.co.jp https://*.clarity.ms https://c.bing.com; connect-src 'self' https://www.google-analytics.com https://www.google.com https://googleads.g.doubleclick.net https://analytics.google.com https://fonts.googleapis.com https://fonts.gstatic.com https://region1.google-analytics.com https://formspree.io https://www.clarity.ms https://*.clarity.ms https://c.bing.com; form-action 'self' https://formspree.io; frame-src https://www.googletagmanager.com https://googleads.g.doubleclick.net" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="徳丸商会｜名古屋のブランド買取。エルメス・シャネル・ヴィトン・ロレックス・カルティエを高価買取。" />
    <meta property="og:site_name" content="徳丸商会｜名古屋のブランド買取" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="徳丸商会｜名古屋のブランド買取。" />

    <!-- 初期表示はヒーローから（hash付きURL・bfcache・scroll restoration 全部を強制リセット） -->
    <script is:inline>
      (function(){
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
        // 初期ロード: hash があってもクリアしてトップへ（単一ページLP仕様）
        if (window.location.hash) {
          history.replaceState(null, '', window.location.pathname + window.location.search);
        }
        var toTop = function(){ window.scrollTo(0, 0); };
        toTop();
        document.addEventListener('DOMContentLoaded', toTop);
        window.addEventListener('load', toTop);
        window.addEventListener('pageshow', function(e){ if (e.persisted) toTop(); });
      })();
    </script>

    <!-- Fonts: 非同期読み込み（FOUT回避: display=swap） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      (function(){
        var l=document.createElement('link');l.rel='stylesheet';
        // モダンミニマル: Inter（Aesop/COS の SuisseIntl 無料代替）+ Cormorant Garamond（Lemaire の Garamond 系セリフ無料代替）+ Noto Sans JP
        l.href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@400;500;600&display=swap';
        document.head.appendChild(l);
      })();
    </script>

    <!-- Google Tag Manager: 3秒遅延（Core Web Vitals保護） -->
    <script is:inline>
      window.dataLayer=window.dataLayer||[];
      setTimeout(function(){
        (function(w,d,s,l,i){w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
        var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
        j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
        f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-W493L98W');
      },3000);
    </script>

    {clarityProjectId && (
      <!-- Microsoft Clarity: 3秒遅延（Core Web Vitals保護）/ pro-lp-launch L1.5 -->
      <script is:inline define:vars={{ clarityProjectId }}>
        setTimeout(function(){
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", clarityProjectId);
        }, 3000);
      </script>
    )}

    <!-- JSON-LD #1: LocalBusiness + PawnShop（@id 参照型・OfferCatalog 内蔵） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "PawnShop"],
      "@id": `${homeUrl}#localbusiness`,
      "name": "徳丸商会",
      "legalName": company.legalName,
      "alternateName": "徳丸商会 ブランド買取",
      "description": "名古屋市中村区横井の古物商。エルメス・シャネル・ヴィトン・ロレックス・カルティエなど主要ブランドのバッグ・時計・ジュエリー・財布・アパレルを、愛知県公安委員会許可の鑑定士が真贋判定込みで査定。出張買取・LINE査定・宅配買取・テレビ電話査定の4チャネル、最短当日訪問・即日入金対応。営業9:00〜21:00 年中無休、累計多数の買取実績。",
      "telephone": company.phone,
      "url": homeUrl,
      "image": ogImage,
      "logo": {
        "@type": "ImageObject",
        "@id": `${homeUrl}#logo`,
        "url": logoUrl,
        "width": 360,
        "height": 360,
        "caption": "徳丸商会 ロゴ"
      },
      "priceRange": "¥¥¥",
      "knowsAbout": [
        "エルメス買取", "シャネル買取", "ルイ・ヴィトン買取",
        "ロレックス買取", "カルティエ買取", "ティファニー買取",
        "ブランドバッグ査定", "ブランド時計査定", "ブランドジュエリー査定",
        "古物商業界", "リユース買取"
      ],
      "makesOffer": [
        { "@type": "Offer", "name": "ブランドバッグ買取（エルメス・シャネル・ヴィトン）", "category": "Brand bag buyback" },
        { "@type": "Offer", "name": "ブランド時計買取（ロレックス・カルティエ・オメガ）", "category": "Brand watch buyback" },
        { "@type": "Offer", "name": "ブランドジュエリー買取（カルティエ・ティファニー・ブルガリ）", "category": "Brand jewelry buyback" },
        { "@type": "Offer", "name": "ブランドアパレル買取", "category": "Brand apparel buyback" },
        { "@type": "Offer", "name": "出張買取（名古屋市16区＋尾張・知多・西三河）", "category": "On-site buyback" },
        { "@type": "Offer", "name": "LINE査定（写真送信で参考買取額をご提示）", "category": "Online assessment" },
        { "@type": "Offer", "name": "宅配買取（送料・キット・返送料すべて無料）", "category": "Mail-in buyback" }
      ],
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "09:00",
        "closes": "21:00"
      }],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "横井2丁目71番地",
        "addressLocality": "名古屋市中村区",
        "addressRegion": "愛知県",
        "postalCode": "453-0863",
        "addressCountry": "JP"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "35.1709",
        "longitude": "136.8815"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "telephone": company.phone,
        "availableLanguage": ["ja"],
        "areaServed": "JP",
        "hoursAvailable": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "09:00",
          "closes": "21:00"
        }
      },
      "areaServed": [
        { "@type": "City", "name": "名古屋市", "containedInPlace": { "@type": "State", "name": "愛知県" } },
        ...company.areas.map(area => ({ "@type": "AdministrativeArea", "name": `名古屋市${area}` })),
        ...company.nearby.map(city => ({ "@type": "City", "name": city, "containedInPlace": { "@type": "State", "name": "愛知県" } }))
      ],
      "sameAs": [company.line],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "ブランド買取サービス",
        "itemListElement": [
          {
            "@type": "OfferCatalog",
            "name": "買取方法",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "出張買取（名古屋市16区＋尾張・知多・西三河）", "serviceType": "出張買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "LINE査定（写真送信で参考買取額を提示）", "serviceType": "オンライン査定" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "宅配買取（送料・キット・返送料すべて無料）", "serviceType": "宅配買取" } }
            ]
          },
          {
            "@type": "OfferCatalog",
            "name": "取扱カテゴリ",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランドバッグ買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランド財布・小物買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランド時計買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランドジュエリー買取" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランドアパレル買取" } }
            ]
          },
          {
            "@type": "OfferCatalog",
            "name": "主要ブランド",
            "itemListElement": flagshipBrands.map((b) => ({
              "@type": "Offer",
              "itemOffered": { "@type": "Service", "name": `${b.jpName}（${b.name}）買取` }
            }))
          }
        ]
      }
    })} />

    <!-- JSON-LD #2: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": company.legalName,
      "alternateName": "徳丸商会",
      "url": homeUrl,
      "brand": {
        "@type": "Brand",
        "name": "徳丸商会"
      },
      "logo": {
        "@type": "ImageObject",
        "@id": `${homeUrl}#logo`,
        "url": logoUrl,
        "width": 360,
        "height": 360,
        "caption": "徳丸商会 ロゴ"
      },
      "knowsAbout": [
        "エルメス買取", "シャネル買取", "ルイ・ヴィトン買取",
        "ロレックス買取", "カルティエ買取", "ティファニー買取",
        "古物商業界", "リユース買取"
      ],
      "telephone": company.phone,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "横井2丁目71番地",
        "addressLocality": "名古屋市中村区",
        "addressRegion": "愛知県",
        "postalCode": "453-0863",
        "addressCountry": "JP"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": company.phone,
        "contactType": "customer support",
        "availableLanguage": "ja",
        "areaServed": "JP"
      },
      "sameAs": [company.line]
    })} />

    <!-- JSON-LD #2.5: WebSite + SearchAction（検索ボックス表示の可能性） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": `${homeUrl}#website`,
      "name": "徳丸商会 ブランド買取",
      "alternateName": "Tokumaru Shokai Brand Buyback",
      "url": homeUrl,
      "publisher": { "@id": `${homeUrl}#localbusiness` },
      "inLanguage": "ja-JP",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${homeUrl}?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- JSON-LD #2.6: Service（独立した買取サービス3種） -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": `${homeUrl}#service-visit`,
        "serviceType": "出張買取",
        "name": "ブランド品の出張買取",
        "description": "名古屋市16区および尾張・知多・西三河エリアへ最短当日訪問。査定員がご自宅に伺い、その場で査定・現金支払い。出張料・査定料・キャンセル料すべて無料。クーリングオフ8日間対応。",
        "provider": { "@id": `${homeUrl}#localbusiness` },
        "areaServed": company.areas.map((a) => ({ "@type": "AdministrativeArea", "name": `名古屋市${a}` })),
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY", "description": "出張料・査定料・キャンセル料すべて無料" }
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": `${homeUrl}#service-line`,
        "serviceType": "オンライン査定",
        "name": "LINE査定（写真送信で参考買取額をご提示）",
        "description": "公式LINEに写真と型番を送るだけ。最短15分で参考買取額をご提示します。営業時間内 9:00〜21:00 年中無休で受付。",
        "provider": { "@id": `${homeUrl}#localbusiness` },
        "areaServed": "JP",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY" }
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": `${homeUrl}#service-mail`,
        "serviceType": "宅配買取",
        "name": "ブランド品の宅配買取",
        "description": "全国対応の宅配買取。専用ダンボールを無料お届け、送料・返送料すべて無料。最大5,000万円までの運送保険付き。査定後最短当日に銀行振込でお支払い。",
        "provider": { "@id": `${homeUrl}#localbusiness` },
        "areaServed": "JP",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY", "description": "送料・キット代・返送料すべて無料" }
      }
    ])} />

    <!-- JSON-LD #3: FAQPage（src/data/faq.ts より自動生成） -->
    <script type="application/ld+json" set:html={JSON.stringify(faqsToJsonLd())} />

    <!-- JSON-LD #4: HowTo（買取の流れ 3ステップ） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "名古屋でブランド品の買取を依頼する方法",
      "description": "徳丸商会のブランド買取サービスを利用する手順。電話またはLINEのお問い合わせから、出張買取・LINE査定・宅配買取いずれかをお選びいただき、現金または銀行振込でお支払いまでをご案内します。",
      "totalTime": "PT1H",
      "estimatedCost": { "@type": "MonetaryAmount", "currency": "JPY", "value": "0" },
      "tool": [
        { "@type": "HowToTool", "name": "本人確認書類（運転免許証・健康保険証＋住民票・パスポート等）" },
        { "@type": "HowToTool", "name": "買取希望のブランド品（保証書・箱・付属品があれば一緒に）" }
      ],
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "お電話・LINE・フォームでお問い合わせ",
          "text": "052-990-3968（9:00-21:00 年中無休）または公式LINEで、お持ちのブランド品の写真と型番をお送りください。LINEなら最短15分で参考買取額をご案内します。",
          "url": `${homeUrl}#contact`
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "出張買取・LINE査定・宅配買取からお選び",
          "text": "出張買取は名古屋市内最短当日訪問・出張料無料。宅配買取は宅配キット・送料・返送料すべて無料・最大5,000万円までの運送保険付き。LINE査定はその場で参考買取額を提示。",
          "url": `${homeUrl}#methods`
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "査定・現金または振込でお支払い",
          "text": "経験豊富な査定士が、ブランド・モデル・状態・付属品を確認のうえ買取金額をご提示。ご納得いただければ、出張買取は現金即支払い、宅配買取は最短当日振込でお支払いします。キャンセルもいつでも無料です。",
          "url": `${homeUrl}#flow`
        }
      ]
    })} />

    <!-- JSON-LD #4.5: Person（査定員2名のE-E-A-T強化 + sameAs / aeo-block-engine +3.2x） -->
    <script type="application/ld+json" set:html={JSON.stringify(
      staff.map((s) => ({
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": `${homeUrl}#staff-${s.surnameKana.toLowerCase()}`,
        "name": s.surname,
        "jobTitle": s.role,
        "worksFor": { "@id": `${homeUrl}#localbusiness` },
        "knowsAbout": s.specialty,
        "description": s.message,
        "url": `${homeUrl}#staff-${s.surnameKana.toLowerCase()}`,
        ...(s.sameAs && s.sameAs.length > 0 ? { "sameAs": s.sameAs } : {}),
      }))
    )} />

    <!-- JSON-LD #5: BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "@id": `${homeUrl}#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "ホーム",
          "item": homeUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "ブランド買取（名古屋）",
          "item": homeUrl
        }
      ]
    })} />

    <!-- JSON-LD #6: WebPage（datePublished/dateModified + speakable + 参照ハブ） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": `${homeUrl}#webpage`,
      "url": homeUrl,
      "name": title,
      "description": description,
      "inLanguage": "ja-JP",
      "isPartOf": { "@id": `${homeUrl}#website` },
      "breadcrumb": { "@id": `${homeUrl}#breadcrumb` },
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": ogImage,
        "width": 1200,
        "height": 630
      },
      "about": { "@id": `${homeUrl}#localbusiness` },
      "mainEntity": { "@id": `${homeUrl}#localbusiness` },
      "datePublished": "2026-05-04",
      "dateModified": new Date().toISOString().slice(0, 10),
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", "[data-speakable]"]
      }
    })} />

    <!-- JSON-LD #7: ItemList（買取実績一覧／rateData 自動生成・ロングテールKWに有効） -->
